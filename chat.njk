---
layout: base.njk
title: Live Real Estate Chat Hub
permalink: /chat/
---

<div class="chat-newspaper-wrapper">
  <!-- Primary Main Column (2/3 Width Layout) -->
  <main class="chat-main-panel">
    <div class="chat-header-card">
      <h2>Let's Talk Real Estate</h2>
      <p>Start your chat below to connect directly with Joe</p>
    </div>

    <!-- Tawk.to Static Embed Framework Container Target -->
    <div id="tawk-embed-container" class="chat-widget-canvas">
      <div id="chat-loading-spinner" class="chat-loading-placeholder">
        <div class="spinner"></div>
        <p>Connecting to the real estate chat desk...</p>
      </div>
    </div>
  </main>

  <!-- Sidebar Column (1/3 Width Layout) -->
  <aside class="chat-sidebar-panel">
    <div class="sidebar-metrics-card">
      <h3>Quick Tools & Resources</h3>
      <p>Take a look at some calculators and resources while you chat:</p>
      <ul class="sidebar-links-list">
        <li><a href="/calculators/" class="curved-pill-button">Real Estate Calculators</a></li>
        <li><a href="/resources/" class="curved-pill-button">Additional Resources</a></li>
      </ul>
    </div>

    <div class="sidebar-privacy-card">
      <h3>Privacy Note</h3>
      <p>This website does not track visitors' info. However, our chat provider does need to track a few things to organize the chats, so this page includes the required tracking.</p>
    </div>
  </aside>
</div>

<style>
  /* System Layout Architecture Grid Code */
  .chat-newspaper-wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
    max-width: 1140px;
    margin: 40px auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .chat-main-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .chat-header-card {
    background-color: var(--dynamic-bg-highlight);
    border-left: 4px solid var(--card-accent-color);
    padding: 24px;
    border-radius: 4px;
  }

  .chat-header-card h2 {
    margin: 0 0 10px 0;
    color: inherit;
  }

  .chat-header-card p {
    margin: 0;
    line-height: 1.6;
  }

  /* Inline Widget Container Window Rules */
  .chat-widget-canvas {
    position: relative;
    width: 100%;
    height: 600px;
    border: 1px solid var(--dynamic-bg-highlight);
    border-radius: 8px;
    overflow: hidden;
    background-color: transparent;
  }

  /* Pre-Initialization Connection Screen */
  .chat-loading-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--dynamic-bg-highlight);
    z-index: 1;
    gap: 15px;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--dynamic-bg-highlight);
    border-top-color: var(--card-accent-color);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Sidebar Presentation Decks */
  .chat-sidebar-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-metrics-card, .sidebar-privacy-card {
    background-color: transparent;
    border: 1px solid var(--dynamic-bg-highlight);
    padding: 24px;
    border-radius: 6px;
  }

  .sidebar-metrics-card h3, .sidebar-privacy-card h3 {
    margin: 0 0 12px 0;
    font-size: 1.15rem;
  }

  .sidebar-metrics-card p, .sidebar-privacy-card p {
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 16px 0;
  }

  .sidebar-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Curved Pill Button Refinement Layout Deck */
  .sidebar-links-list .curved-pill-button {
    display: block;
    background-color: var(--dynamic-bg-highlight);
    border: 1px solid var(--card-accent-color);
    color: inherit;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 10px 20px;
    border-radius: 30px;
    text-align: center;
    transition: transform 0.1s ease;
  }

  .sidebar-links-list .curved-pill-button:hover {
    transform: translateY(-1px);
    opacity: 0.9;
  }

  /* Structural Responsive Scaling Rules */
  @media (max-width: 768px) {
    .chat-newspaper-wrapper {
      grid-template-columns: 1fr;
      margin: 20px auto;
    }
    .chat-widget-canvas {
      height: 500px;
    }
  }
</style>

<!-- Context Extraction and Embedded Sync Script Block -->
<script type="text/javascript">
  var Tawk_API = Tawk_API || {};
  var Tawk_LoadStart = new Date();

  // Core Override Contract: Force inline rendering directly within our layout architecture frame container
  Tawk_API.embedded = 'tawk-embed-container';

  // Executed dynamically the precise instant communication protocols initialize
  Tawk_API.onLoad = function() {
    // Clear out the custom connection placeholder graphic loading element
    const spinner = document.getElementById('chat-loading-spinner');
    if (spinner) {
      spinner.style.display = 'none';
    }

    // Capture layout context properties passed forward from your neighborhood blog posts
    const urlParams = new URLSearchParams(window.location.search);
    const postRoutePath = urlParams.get('reply_to');

    if (postRoutePath) {
      // Decode the URL string parameters to safely reconstruct slashes, hyphens, and dates completely
      const decodedPath = decodeURIComponent(postRoutePath);
      const completePostUrl = window.location.origin + decodedPath;

      // Inject clean, active, clickable context hyperlinks directly into your agent dashboard console
      Tawk_API.setAttributes({
        'Source Post Path': decodedPath,
        'Direct Post Link': completePostUrl
      }, function(error) {
        if (error) {
          console.error('Context alignment sync issue:', error);
        }
      });
    }
  };

  // Wrap network parsing inside a DOMContentLoaded event handler to guarantee the HTML structure loads before executing script hooks
  window.addEventListener('DOMContentLoaded', function() {
    var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
    s1.async = true;
    s1.src = 'https://embed.tawk.to/6a5b0cb0efae261d44936bbd/1jtpqj4im';
    s1.charset = 'UTF-8';
    s1.setAttribute('crossorigin', '*');
    s0.parentNode.insertBefore(s1, s0);
  });
</script>