<div class="chat-newspaper-wrapper">
  <!-- Primary Main Column (2/3 Width Layout) -->
  <main class="chat-main-panel">
    <div class="chat-header-card">
      <h2>Let's Talk Real Estate Data</h2>
      <p>Whether you're looking over a local market loop, analyzing home sale variables, or mapping out your moving timeline, drop your questions right into the workspace below. I'm here to coach you through the numbers and clarify the path forward.</p>
    </div>

    <!-- Tawk.to Static Embed Framework Container -->
    <div id="tawk-embed-container" class="chat-widget-canvas">
      <div id="chat-loading-spinner" class="chat-loading-placeholder">
        <div class="spinner"></div>
        <p>Connecting to the real estate chat desk...</p>
      </div>
    </div>
  </main>

  <!-- Sidebar Column (1/3 Width Layout) -->
  <aside class="chat-sidebar-panel">
    <div class="sidebar-metrics-card">
      <h3>Quick Tools & Resources</h3>
      <p>Want to model out your financial strategies while we talk? Open these real estate trackers in a separate browser tab:</p>
      <ul class="sidebar-links-list">
        <li><a href="/calculators.html">Calculators Dashboard</a></li>
        <li><a href="/sellerproceeds.html">Estimated Net Proceeds</a></li>
        <li><a href="/rentvsbuy.html">Rent vs. Buy Modeler</a></li>
        <li><a href="/loancompare.html">Loan Program Comparison</a></li>
        <li><a href="/buynowvslater.html">Buy Now or Later Modeler</a></li>
      </ul>
    </div>

    <div class="sidebar-privacy-card">
      <h3>Privacy Guaranteed</h3>
      <p>This panel is completely isolated. Script tracking only executes inside this view block and terminates automatically when you leave the workspace.</p>
    </div>
  </aside>
</div>

<style>
  /* System Layout Architecture Grid Code */
  .chat-newspaper-wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 30px;
    max-width: 1140px;
    margin: 40px auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .chat-main-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .chat-header-card {
    background-color: var(--dynamic-bg-highlight);
    border-left: 4px solid var(--card-accent-color);
    padding: 24px;
    border-radius: 4px;
  }

  .chat-header-card h2 {
    margin: 0 0 10px 0;
  }

  .chat-header-card p {
    margin: 0;
    line-height: 1.6;
  }

  /* Inline Widget Container Window Rules */
  .chat-widget-canvas {
    position: relative;
    width: 100%;
    height: 600px;
    border: 1px solid var(--dynamic-bg-highlight);
    border-radius: 8px;
    overflow: hidden;
  }

  /* Pre-Initialization Connection Screen */
  .chat-loading-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--dynamic-bg-highlight);
    z-index: 1;
    gap: 15px;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--dynamic-bg-highlight);
    border-top-color: var(--card-accent-color);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Sidebar Presentation Decks */
  .chat-sidebar-panel {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-metrics-card, .sidebar-privacy-card {
    border: 1px solid var(--dynamic-bg-highlight);
    padding: 24px;
    border-radius: 6px;
  }

  .sidebar-metrics-card h3, .sidebar-privacy-card h3 {
    margin: 0 0 12px 0;
    font-size: 1.15rem;
  }

  .sidebar-metrics-card p, .sidebar-privacy-card p {
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 16px 0;
  }

  .sidebar-links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sidebar-links-list a {
    display: inline-block;
    color: var(--card-accent-color);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
  }

  .sidebar-links-list a:hover {
    text-decoration: underline;
  }

  /* Structural Responsive Scaling Rules */
  @media (max-width: 768px) {
    .chat-newspaper-wrapper {
      grid-template-columns: 1fr;
      margin: 20px auto;
    }
    .chat-widget-canvas {
      height: 500px;
    }
  }
</style>

<!-- Context Extraction and Embedded Sync Script Block -->
<script type="text/javascript">
  var Tawk_API = Tawk_API || {};
  var Tawk_LoadStart = new Date();

  // Core Override Contract: Anchor chat frame directly into our center canvas div layout instead of spawning a bubble in the corner
  Tawk_API.container = 'tawk-embed-container';

  // Executed dynamically the instant communication parameters initialize
  Tawk_API.onLoad = function() {
    // Wipe out the loading placeholder wheel animation cleanly
    const spinner = document.getElementById('chat-loading-spinner');
    if (spinner) {
      spinner.style.display = 'none';
    }

    // Read context loops passed directly from your neighborhood blog parameters
    const urlParams = new URLSearchParams(window.location.search);
    const postRoutePath = urlParams.get('reply_to');

    if (postRoutePath) {
      // Build out fully qualified absolute hyperlinks to sync with your Redfin dashboard metrics
      const completePostUrl = window.location.origin + postRoutePath;

      Tawk_API.setAttributes({
        'Source Post Path': postRoutePath,
        'Direct Post Link': completePostUrl
      }, function(error) {
        if (error) {
          console.error('Context alignment sync issue:', error);
        }
      });
    }
  };

  // Execution injection routine targeting your specific widget routing path
  (function() {
    var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
    s1.async = true;
    s1.src = 'https://embed.tawk.to/6a5b0cb0efae261d44936bbd/1jtpqj4im';
    s1.charset = 'UTF-8';
    s1.setAttribute('crossorigin', '*');
    s0.parentNode.insertBefore(s1, s0);
  })();
</script>