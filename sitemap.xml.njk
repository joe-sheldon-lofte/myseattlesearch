---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- for page in collections.all %}
  {%- if page.url and not page.data.draft and not ('404' in page.url) %}
  <url>
    <loc>https://myseattlesearch.com{{ page.url }}</loc>
    <lastmod>{{ page.date.toISOString().slice(0, 10) }}</lastmod>
    {%- if page.data.city and page.data.city['North Sound'] | lower == 'x' %}
    <changefreq>hourly</changefreq>
    <priority>0.9</priority>
    {%- elif '/news/' in page.url %}
    <changefreq>hourly</changefreq>
    <priority>0.8</priority>
    {%- elif '/notebook/' in page.url or '/posts/' in page.url %}
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
    {%- elif '/events/' in page.url %}
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
    {%- elif page.data.city %}
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
    {%- elif page.url in ['/downpayment/', '/thirdpartyprograms/', '/rentvsbuy/', '/sellerproceeds/', '/loancomp/', '/buynowvslater/'] or '/calculators/' in page.url %}
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
    {%- else %}
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
    {%- endif %}
  </url>
  {%- endif %}
{%- endfor %}
</urlset>