<div class="tpp-container">
    
    <section class="tpp-header">
        <h1>Specialty Home Programs</h1>
        <p>Standard financing options don't fit every layout. Explore our direct integration pathways with premium third-party trust funds, contingency busters, and renovation solutions built to optimize your leverage.</p>
    </section>

    <div class="tpp-filter-bar">
        <button type="button" class="filter-chip active" data-filter="all">Show All Programs</button>
        <button type="button" class="filter-chip" data-filter="buyer">For Home Buyers</button>
        <button type="button" class="filter-chip" data-filter="seller">For Home Sellers</button>
    </div>

    <div id="programs-mount-node" class="tpp-grid">
        <div class="tpp-loading-frame">Syncing active program marketplace files...</div>
    </div>

</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const mountNode = document.getElementById('programs-mount-node');
        const chips = document.querySelectorAll('.filter-chip');
        
        const jsonEndpointUrl = '/data/thirdpartyprograms.json';
        let masterProgramsDataset = [];

        // Fetch local database archive natively with zero external dependencies
        fetch(jsonEndpointUrl)
            .then(res => {
                if (!res.ok) throw new Error("Local dataset path failed");
                return res.json();
            })
            .then(data => {
                // Support both flat layout array streams and wrapper objects
                const rawRows = Array.isArray(data) ? data : (data.programs || data.data || []);
                
                masterProgramsDataset = rawRows.filter(row => {
                    return row['Display'] && row['Display'].trim().toLowerCase() === 'yes';
                });
                
                renderProgramCards('all');
            })
            .catch(err => {
                console.error("Specialty program retrieval track interrupted:", err);
                mountNode.innerHTML = `<div class="tpp-empty-state">Unable to load program parameters right now. Please hit reply or check back shortly.</div>`;
            });

        // Card compilation framework routing script engine
        function renderProgramCards(filterScope) {
            let htmlOutput = '';
            
            const filteredRows = masterProgramsDataset.filter(program => {
                if (filterScope === 'all') return true;
                
                const audience = program['Target Audience'] ? program['Target Audience'].trim().toLowerCase() : '';
                return audience.includes(filterScope) || audience === 'both';
            });

            if (filteredRows.length === 0) {
                mountNode.innerHTML = `<div class="tpp-empty-state">No specialty programs matching this filter configuration are registered at this time.</div>`;
                return;
            }

            filteredRows.forEach(p => {
                htmlOutput += `
                    <div class="tpp-card">
                        <div class="card-top-block">
                            <span class="category-badge">${p['Category'] || 'Specialty Track'}</span>
                            <h3>${p['Program Name'] || 'Alternative Solution'}</h3>
                            
                            <div class="stress-callout-box">
                                <p>📦 ${p['Summary'] || 'Strategic Optimization'}</p>
                            </div>
                            
                            <p class="program-hook-text">${p['Purpose'] || ''}</p>
                        </div>
                        
                        <div class="card-bottom-block">
                            <div class="metadata-spec-list">
                                <div class="spec-item"><strong>Estimated Fees:</strong> ${p['Client Fees & Costs'] || 'Contact for custom estimation'}</div>
                                <div class="spec-item"><strong>Primary Edge:</strong> ${p['Benefit'] || 'Enhanced negotiation power'}</div>
                                <div class="spec-item"><strong>Criteria:</strong> ${p['Property Restrictions'] || 'Subject to local appraisal standards'}</div>
                            </div>
                            
                            <a href="${p['Website URL'] || '#'}" target="_blank" class="btn btn-primary" style="text-align:center; display:block; text-decoration:none; font-weight:bold; font-size:0.9rem; background: var(--card-accent-color); color: var(--white, #ffffff); border: none; border-radius: 6px; padding: 0.6rem 1rem;">
                                Analyze Program Details &rarr;
                            </a>
                        </div>
                    </div>
                `;
            });

            mountNode.innerHTML = htmlOutput;
        }

        // Click handling event engine for filter controls
        chips.forEach(chip => {
            chip.addEventListener('click', () => {
                chips.forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
                
                const targetedFilterType = chip.getAttribute('data-filter');
                renderProgramCards(targetedFilterType);
            });
        });
    });
</script>