layout: base.njk
title: "King & Snohomish County Property Tax Calculator | Joe Sheldon"
permalink: /propertytax/
---

<div class="centered-calculator-container">
    <div class="calculator-focus-card">
        <header class="calculator-header-block">
            <span class="calculator-tagline">Local Market Clarity</span>
            <h1 class="calculator-headline">Property Tax Estimator</h1>
            <p class="calculator-coaching-text">
                Select your county and city, then provide your property's <strong>Assessed Value</strong>. Remember, your assessed value is determined by county tax appraisers and is usually lower than your home's actual retail market value.
            </p>
        </header>

        <form class="calculator-form-deck" onsubmit="return false;">
            <div class="form-field-group">
                <label for="county-select" class="form-field-label">1. Select County</label>
                <select id="county-select" class="form-field-control" onchange="handleCountySwitch()">
                    <option value="">Choose a County</option>
                </select>
            </div>

            <div class="form-field-group">
                <label for="city-select" class="form-field-label">2. Select Municipality / City Location</label>
                <select id="city-select" class="form-field-control" disabled onchange="executeTaxCalculation()">
                    <option value="">Choose a City</option>
                </select>
            </div>

            <div class="form-field-group">
                <label for="assessed-value-input" class="form-field-label">3. Assessed Property Value ($)</label>
                <input type="text" id="assessed-value-input" class="form-field-control" placeholder="e.g. 750,000" disabled onkeyup="formatInputAndCalculate(this)">
                <small class="form-input-help">Washington calculates taxes based on rate brackets per $1,000 of assessed valuation.</small>
            </div>
        </form>

        <div id="results-display-board" class="results-hidden">
            <div class="result-metric-segment">
                <span class="result-metric-label">Estimated Annual Property Tax</span>
                <div id="annual-tax-output" class="result-metric-value">$0.00</div>
                <span id="rate-context-label" class="result-metric-subtext">Consolidated District Rate</span>
            </div>
            
            <div class="result-metric-divider"></div>
            
            <div class="result-metric-segment">
                <span class="result-metric-label">Monthly Escrow Allocation Impact</span>
                <div id="monthly-tax-output" class="result-metric-value monthly-accent">$0.00 / mo</div>
                <span class="result-metric-subtext">Added to base principal & interest payment</span>
            </div>
        </div>
    </div>
</div>

<style>
    .centered-calculator-container {
        max-width: 1000px;
        margin: 4rem auto;
        padding: 0 1.5rem;
        min-height: 70vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        box-sizing: border-box;
    }
    
    .calculator-focus-card {
        max-width: 600px;
        width: 100%;
        background: #ffffff;
        border: 1px solid #eeeeee;
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border-top: 6px solid var(--card-accent-color);
        box-sizing: border-box;
    }

    .calculator-header-block {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .calculator-tagline {
        font-size: 0.8rem;
        font-weight: 800;
        color: var(--card-accent-color);
        text-transform: uppercase;
        letter-spacing: 1.5px;
        display: block;
        margin-bottom: 0.5rem;
    }

    .calculator-headline {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: #222222;
        margin: 0 0 1rem 0;
    }

    .calculator-coaching-text {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #555555;
        margin: 0;
    }

    .calculator-form-deck {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .form-field-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-field-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: #333333;
    }

    .form-field-control {
        width: 100%;
        padding: 0.85rem 1rem;
        font-size: 1rem;
        border: 1px solid #cccccc;
        border-radius: 8px;
        background-color: #ffffff;
        color: #222222;
        box-sizing: border-box;
        font-family: inherit;
        transition: border-color 0.15s ease;
    }

    .form-field-control:focus {
        outline: none;
        border-color: var(--card-accent-color);
    }

    .form-field-control:disabled {
        background-color: #fafafa;
        color: #aaaaaa;
        cursor: not-allowed;
    }

    .form-input-help {
        font-size: 0.8rem;
        color: #777777;
        line-height: 1.4;
    }

    /* Interactive Results Interface Elements */
    #results-display-board {
        background-color: var(--dynamic-bg-highlight);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        box-sizing: border-box;
        transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .results-hidden {
        opacity: 0;
        transform: translateY(10px);
        pointer-events: none;
    }

    .result-metric-segment {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .result-metric-label {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #666666;
    }

    .result-metric-value {
        font-size: 2.25rem;
        font-weight: 800;
        color: #222222;
        letter-spacing: -0.5px;
    }

    .result-metric-value.monthly-accent {
        color: var(--card-accent-color);
    }

    .result-metric-subtext {
        font-size: 0.8rem;
        color: #666666;
        font-weight: 500;
    }

    .result-metric-divider {
        height: 1px;
        background-color: rgba(0,0,0,0.06);
        width: 100%;
    }
</style>

<script>
    // Global template storage matrix containing county data indexes
    let countyTaxDataMatrix = null;

    // Secure Ingestion Pass: Immediate execution avoids DOMContentLoaded timing race conditions
    fetch('/data/property_tax_rates.json')
        .then(response => {
            if (!response.ok) throw new Error('Data pipeline missing file structure');
            return response.json();
        })
        .then(data => {
            countyTaxDataMatrix = data;
            populateCountySelector();
        })
        .catch(error => {
            console.error('❌ Calculator error initializing tax metrics map:', error);
        });

    function populateCountySelector() {
        const countyMenu = document.getElementById("county-select");
        if (!countyTaxDataMatrix || !countyTaxDataMatrix.counties) return;

        countyTaxDataMatrix.counties.forEach((county, idx) => {
            const optionItem = document.createElement("option");
            optionItem.value = idx;
            optionItem.textContent = county.name;
            countyMenu.appendChild(optionItem);
        });
    }

    function handleCountySwitch() {
        const countyMenu = document.getElementById("county-select");
        const cityMenu = document.getElementById("city-select");
        const valueInput = document.getElementById("assessed-value-input");
        const resultsBoard = document.getElementById("results-display-board");

        // Clear and lock downstream form elements if empty choice made
        cityMenu.innerHTML = '<option value="">Choose a City</option>';
        cityMenu.disabled = true;
        valueInput.disabled = true;
        resultsBoard.classList.add("results-hidden");

        const selectedIndex = countyMenu.value;
        if (selectedIndex === "") return;

        const activeCounty = countyTaxDataMatrix.counties[selectedIndex];
        activeCounty.cities.forEach((city, idx) => {
            const optionItem = document.createElement("option");
            optionItem.value = idx;
            optionItem.textContent = `${city.name} (${city.effectiveRate})`;
            cityMenu.appendChild(optionItem);
        });

        cityMenu.disabled = false;
    }

    function formatInputAndCalculate(inputField) {
        // Clean out any accidental alphabetic or symbol formats to leave raw numerical values
        let numericString = inputField.value.replace(/[^0-9.]/g, "");
        
        // Handle floating layout decimals safely
        const decimalSplits = numericString.split(".");
        if (decimalSplits.length > 2) {
            numericString = decimalSplits[0] + "." + decimalSplits.slice(1).join("");
        }

        // Format clean comma visual layout anchors as they type
        if (numericString) {
            const structuralParts = numericString.split(".");
            structuralParts[0] = parseInt(structuralParts[0], 10).toLocaleString("en-US");
            inputField.value = structuralParts.join(".");
        } else {
            inputField.value = "";
        }

        executeTaxCalculation();
    }

    function executeTaxCalculation() {
        const countyMenu = document.getElementById("county-select");
        const cityMenu = document.getElementById("city-select");
        const valueInput = document.getElementById("assessed-value-input");
        const resultsBoard = document.getElementById("results-display-board");

        // Enable input element the moment city option is mapped
        if (cityMenu.value !== "") {
            valueInput.disabled = false;
        } else {
            valueInput.disabled = true;
            resultsBoard.classList.add("results-hidden");
            return;
        }

        // Extract raw number value
        const rawHomeValue = parseFloat(valueInput.value.replace(/,/g, ""));
        
        if (isNaN(rawHomeValue) || rawHomeValue <= 0) {
            resultsBoard.classList.add("results-hidden");
            return;
        }

        const selectedCountyIdx = countyMenu.value;
        const selectedCityIdx = cityMenu.value;
        
        const cityDataNode = countyTaxDataMatrix.counties[selectedCountyIdx].cities[selectedCityIdx];
        const localLevyRate = cityDataNode.levyRate;

        // Washington Property Tax Formula Contract: (Assessed Value / 1000) * Levy Rate
        const calculatedAnnualTaxes = (rawHomeValue / 1000) * localLevyRate;
        const calculatedMonthlyEscrow = calculatedAnnualTaxes / 12;

        // Inject figures directly into output nodes
        document.getElementById("annual-tax-output").textContent = 
            `$${calculatedAnnualTaxes.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
        
        document.getElementById("monthly-tax-output").textContent = 
            `$${calculatedMonthlyEscrow.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2})} / mo`;
            
        document.getElementById("rate-context-label").textContent = 
            `Consolidated District Rate: $${localLevyRate.toFixed(4)} per $1,000 assessed value (${cityDataNode.effectiveRate})`;

        // Dynamic element appearance step
        resultsBoard.classList.remove("results-hidden");
    }
</script>