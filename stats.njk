---
layout: base.njk
title: "Local Community Insights | Joe Sheldon"
permalink: /stats/
containerClass: container-wide
---

<style>
    .stats-hub-container {
        width: 100%;
        margin: 0 auto;
    }

    .events-header {
        text-align: center;
        margin-bottom: 3rem;
    }
    
    .events-header h1 {
        margin-top: 3rem;
        font-size: 2.8rem;
        font-weight: 900;
        color: var(--card-accent-color);
    }

    .intro {
        font-size: 1.15rem;
        color: var(--premier-charcoal);
        max-width: 600px;
        margin: 1rem auto 0;
    }

    /* North Sound Pill Buttons */
    .section-title {
        text-align: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--premier-charcoal);
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .pill-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 4rem;
    }

    .pill-btn {
        display: inline-flex;
        align-items: center;
        padding: 0.6rem 1.5rem;
        background: var(--dynamic-bg-highlight);
        border: 2px solid var(--premier-beige);
        border-radius: 50px;
        color: var(--premier-charcoal);
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.2s ease;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    .pill-btn:hover {
        border-color: var(--card-accent-color);
        background: var(--card-accent-color);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    /* Dropdown Layout */
    .county-dropdowns-wrapper {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
        background: var(--dynamic-bg-highlight);
        padding: 1.5rem 1rem; /* Compact mobile padding to stop narrow card breaks */
        border-radius: 12px;
        border: 1px solid var(--premier-beige);
    }

    @media (min-width: 768px) {
        .county-dropdowns-wrapper {
            grid-template-columns: 1fr 1fr;
            padding: 2.5rem; /* Cozy widescreen padding spacing layout */
        }
    }

    .dropdown-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .dropdown-group label {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--premier-charcoal);
    }

    .modern-select {
        padding: 1rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--premier-charcoal);
        background-color: white;
        border: 2px solid var(--premier-beige);
        border-radius: 8px;
        outline: none;
        cursor: pointer;
        transition: border-color 0.2s ease;
        appearance: none;
        background-image: url('data:image/svg+xml;utf8,<svg fill="%23333" height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg"><path d="M7 10l5 5 5-5z"/><path d="M0 0h24v24H0z" fill="none"/></svg>');
        background-repeat: no-repeat;
        background-position-x: 96%;
        background-position-y: 50%;
    }

    .modern-select:hover, .modern-select:focus {
        border-color: var(--card-accent-color);
    }
</style>

<div class="stats-hub-container">
    
    <div class="events-header">
        <h1>Local Community Insights</h1>
        <p class="intro">Real-time data, historical housing trends, and neighborhood metrics for the Pacific Northwest.</p>
    </div>

    <div id="directory-content">
        
        <h2 class="section-title">North Sound</h2>
 
        <div id="north-sound-pills" class="pill-container">
            {% set seen_pills = "" %}
            {% for city in city_data | sort(attribute="City") %}
                {% if city['North Sound'] and (city['North Sound'] == 'x' or city['North Sound'] == 'yes' or city['North Sound'] == 'X' or city['North Sound'] == 'Yes') %}
                    {% if not ("|" + city.City + "|" in seen_pills) %}
                        {% set seen_pills = seen_pills + "|" + city.City + "|" %}
                        <a href="/communities/{{ city.City | slugify }}/stats/" class="pill-btn" rel="prefetch">{{ city.City }}</a>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>

        <h2 class="section-title" style="margin-top: 4rem;">Explore By County</h2>
        <div class="county-dropdowns-wrapper">
            
            <div class="dropdown-group">
                <label for="king-county-select">King County</label>
                <select id="king-county-select" class="modern-select">
                    <option value="">Select a community...</option>
                    {% set seen_king = "" %}
                    {% for city in city_data | sort(attribute="City") %}
                        {% if city.County and "king" in city.County | lower %}
                            {% if not ("|" + city.City + "|" in seen_king) %}
                                {% set seen_king = seen_king + "|" + city.City + "|" %}
                                <option value="/communities/{{ city.City | slugify }}/stats/">{{ city.City }}</option>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </select>
            </div>

            <div class="dropdown-group">
                <label for="snohomish-county-select">Snohomish County</label>
                <select id="snohomish-county-select" class="modern-select">
                   <option value="">Select a community...</option>
                    {% set seen_sno = "" %}
                    {% for city in city_data | sort(attribute="City") %}
                        {% if city.County and "snohomish" in city.County | lower %}
                            {% if not ("|" + city.City + "|" in seen_sno) %}
                                {% set seen_sno = seen_sno + "|" + city.City + "|" %}
                                <option value="/communities/{{ city.City | slugify }}/stats/">{{ city.City }}</option>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </select>
            </div>

        </div>
    </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const kingSelect = document.getElementById('king-county-select');
    const snohomishSelect = document.getElementById('snohomish-county-select');

    const navigateToCity = (e) => {
        const url = e.target.value;
        if (url) window.location.href = url;
    };

    if (kingSelect) kingSelect.addEventListener('change', navigateToCity);
    if (snohomishSelect) snohomishSelect.addEventListener('change', navigateToCity);
});
</script>