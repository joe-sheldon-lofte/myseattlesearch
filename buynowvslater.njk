<script>
    let parsedFeedRatesRegistry = {
        'Conventional': 6.50,
        'FHA': 6.125,
        'VA': 6.125
    };

    function updateDisplayedRate() {
        const loanType = document.getElementById('inLoanType').value;
        if (parsedFeedRatesRegistry[loanType]) {
            document.getElementById('inRateNow').value = parsedFeedRatesRegistry[loanType].toFixed(3);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        fetch('/data/hourly_rates.json')
            .then(response => response.json())
            .then(rows => {
                if (rows && rows.length > 0) {
                    const validRows = rows.filter(r => Object.values(r)[0] && String(Object.values(r)[0]).trim() !== '');
                    validRows.sort((a, b) => new Date(Object.values(a)[0].split(' ')[0]) - new Date(Object.values(b)[0].split(' ')[0]));
                    const latestRow = validRows[validRows.length - 1];
                    const latestVals = Object.values(latestRow);
                    
                    const convRate = parseFloat(latestVals[1]);
                    const fhaRate = parseFloat(latestVals[2]);
                    const vaRate = parseFloat(latestVals[3]);

                    if (!isNaN(convRate)) parsedFeedRatesRegistry['Conventional'] = convRate;
                    if (!isNaN(fhaRate)) parsedFeedRatesRegistry['FHA'] = fhaRate;
                    if (!isNaN(vaRate)) parsedFeedRatesRegistry['VA'] = vaRate;
                    
                    updateDisplayedRate();
                }
            })
            .catch(error => console.error("Error loading live rates, defaulting to reference baselines", error));

        const categoriesPath = '/data/city_data.json';
        const infosparksPath = '/data/infosparks_stats.json';

        let dataStore = { cities: {}, infosparks: {}, computedAppreciation: 4.5 };

        const cleanNum = (str) => {
            if (str === null || str === undefined || str === 'NaN') return 0;
            return parseFloat((str).toString().replace(/[^0-9.-]+/g, "")) || 0;
        };
        const formatCurrency = (num) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);

        const fetchJSON = async (path) => {
            try { const res = await fetch(path); if (!res.ok) return null; return JSON.parse((await res.text()).replace(/:\s*NaN/g, ": null")); } catch (e) { return null; }
        };

        Promise.all([
            fetchJSON(categoriesPath), fetchJSON(infosparksPath)
        ]).then(values => {
            const categoryRows = values[0] || [];
            const is = values[1];
            dataStore.infosparks = is && is.feeds ? is.feeds : (is || {});

            categoryRows.forEach(row => {
                if (row.City) {
                    dataStore.cities[row.City.trim().toLowerCase()] = { city: row.City.trim() };
                }
            });
            populateDropdown();
        });

        function populateDropdown() {
            const select = document.getElementById('citySelect');
            let optionsHtml = '';
            Object.values(dataStore.cities).sort((a,b) => a.city.localeCompare(b.city)).forEach(item => {
                optionsHtml += `<option value="${item.city}">${item.city}</option>`;
            });
            select.innerHTML = optionsHtml;
            select.addEventListener('change', handleCityChange);
            handleCityChange();
        }

        function handleCityChange() {
            const city = document.getElementById('citySelect').value;
            const target = city.toLowerCase().trim();
            let timeline = [];

            for (let feedKey in dataStore.infosparks) {
                if (feedKey.toLowerCase().includes('median_sale_price')) {
                    const feed = dataStore.infosparks[feedKey];
                    let rows = Array.isArray(feed) ? feed : (feed.data || []);
                    
                    if (rows.length > 0) {
                        const validRow = rows.find(r => r.Date && !String(r.Date).includes("All data from"));
                        if (validRow && Object.keys(validRow).some(k => k.toLowerCase().trim() === target)) {
                            timeline = rows.filter(row => {
                                if (!row || !row.Date || String(row.Date).includes("All data from")) return false;
                                let v = row[Object.keys(row).find(k => k.toLowerCase().trim() === target)];
                                return v !== null && v !== undefined && v !== 'NaN' && !Number.isNaN(v);
                            }).map(row => cleanNum(row[Object.keys(row).find(k => k.toLowerCase().trim() === target)]));
                        }
                    }
                }
            }

            let appreciationRate = 4.5; 
            let currentMedian = 800000;

            if (timeline.length > 1) {
                currentMedian = timeline[timeline.length - 1];
                const earliestPrice = timeline[0];
                const totalPoints = timeline.length;
                if (totalPoints >= 12) {
                    const years = totalPoints / 12;
                    appreciationRate = (Math.pow((currentMedian / earliestPrice), (1 / years)) - 1) * 100;
                } else {
                    appreciationRate = ((currentMedian / earliestPrice) - 1) * 100;
                }
                if (appreciationRate < -10 || appreciationRate > 20 || isNaN(appreciationRate)) {
                    appreciationRate = 4.5;
                }
            }

            dataStore.computedAppreciation = appreciationRate;
            document.getElementById('lblAppreciationRate').textContent = appreciationRate.toFixed(1) + '%';
            document.getElementById('inPriceOverride').value = currentMedian;
        }

        window.calculateCostOfWaiting = function() {
            const city = document.getElementById('citySelect').value;
            const waitYears = parseFloat(document.getElementById('inWaitTime').value);
            const loanType = document.getElementById('inLoanType').value;
            const baseRent = parseFloat(document.getElementById('inRent').value) || 0;
            const priceNow = parseFloat(document.getElementById('inPriceOverride').value) || 0;
            const rateNow = parseFloat(document.getElementById('inRateNow').value) || 6.5;
            const rateLater = parseFloat(document.getElementById('inRateLater').value) || 5.75;
            const downValNow = parseFloat(document.getElementById('inDownValueNow').value) || 0;
            const downUnitNow = document.getElementById('inDownUnitNow').value;
            const downValLater = parseFloat(document.getElementById('inDownValueLater').value) || 0;
            const downUnitLater = document.getElementById('inDownUnitLater').value;

            const annualAppreciation = dataStore.computedAppreciation / 100;

            let cashDownNow = (downUnitNow === '%') ? priceNow * (downValNow / 100) : downValNow;
            let loanAmountNow = priceNow - cashDownNow;
            if (loanType === 'FHA') loanAmountNow += (loanAmountNow * 0.0175);
            else if (loanType === 'VA') loanAmountNow += (loanAmountNow * 0.0215);

            const monthlyPINow = calculateAmortization(loanAmountNow, rateNow);
            const taxAndInsNow = (priceNow * 0.009 / 12) + 120; 
            let pmiNow = 0;
            if (loanType === 'Conventional' && (cashDownNow / priceNow) < 0.20) pmiNow = (loanAmountNow * 0.005 / 12);
            else if (loanType === 'FHA') pmiNow = (loanAmountNow * 0.0055 / 12);
            const totalPaymentNow = monthlyPINow + taxAndInsNow + pmiNow;

            const priceLater = priceNow * Math.pow(1 + annualAppreciation, waitYears);
            let cashDownLater = (downUnitLater === '%') ? priceLater * (downValLater / 100) : downValLater;
            let loanAmountLater = priceLater - cashDownLater;
            if (loanType === 'FHA') loanAmountLater += (loanAmountLater * 0.0175);
            else if (loanType === 'VA') loanAmountLater += (loanAmountLater * 0.0215);

            const monthlyPILater = calculateAmortization(loanAmountLater, rateLater);
            const taxAndInsLater = (priceLater * 0.009 / 12) + 120;
            let pmiLater = 0;
            if (loanType === 'Conventional' && (cashDownLater / priceLater) < 0.20) pmiLater = (loanAmountLater * 0.005 / 12);
            else if (loanType === 'FHA') pmiLater = (loanAmountLater * 0.0055 / 12);
            const totalPaymentLater = monthlyPILater + taxAndInsLater + pmiLater;

            const priceIncreasePenalty = priceLater - priceNow;
            const totalRentSunk = baseRent * 12 * waitYears;
            
            let trackingBalance = loanAmountNow;
            const monthlyRateNow = (rateNow / 100) / 12;
            const totalMonthsToWait = waitYears * 12;
            let accumulatedPaydown = 0;

            for (let m = 1; m <= totalMonthsToWait; m++) {
                const interestCharge = trackingBalance * monthlyRateNow;
                const principalReduction = monthlyPINow - interestCharge;
                accumulatedPaydown += principalReduction;
                trackingBalance -= principalReduction;
            }

            const absoluteFinancialLoss = priceIncreasePenalty + totalRentSunk + accumulatedPaydown;

            document.getElementById('valPriceNow').textContent = formatCurrency(priceNow);
            document.getElementById('valPriceLater').textContent = formatCurrency(priceLater);
            document.getElementById('valDownNow').textContent = formatCurrency(cashDownNow);
            document.getElementById('valDownLater').textContent = formatCurrency(cashDownLater);
            document.getElementById('valPaymentNow').textContent = formatCurrency(totalPaymentNow) + '/mo';
            document.getElementById('valPaymentLater').textContent = formatCurrency(totalPaymentLater) + '/mo';
            document.getElementById('valRentSunk').textContent = formatCurrency(totalRentSunk);
            document.getElementById('valMissedPaydown').textContent = formatCurrency(accumulatedPaydown);

            document.getElementById('descPriceChase').textContent = `Based on historical trends in ${city}, a waiting period of ${waitYears} ${waitYears === 1 ? 'year' : 'years'} is projected to shift the purchase price from ${formatCurrency(priceNow)} to ${formatCurrency(priceLater)}, a difference of ${formatCurrency(Math.abs(priceIncreasePenalty))}.`;
            const extraSavingsTarget = cashDownLater - cashDownNow;
            if (extraSavingsTarget > 0) {
                document.getElementById('descDownTrap').textContent = `With a projected price change of ${formatCurrency(priceIncreasePenalty)}, saving an additional ${formatCurrency(extraSavingsTarget)} results in an estimated future loan balance of ${formatCurrency(loanAmountLater)}, compared to a balance of ${formatCurrency(loanAmountNow)} if purchasing today.`;
            } else {
                document.getElementById('descDownTrap').textContent = `This tracks how changes in the purchase price alter the relationship between your available down payment savings and the remaining loan size.`;
            }

            const incomeNow = (totalPaymentNow / 0.33) * 12;
            const incomeLater = (totalPaymentLater / 0.33) * 12;
            document.getElementById('descBreakdownQualifying').textContent = `Based on a standard lending allocation for housing costs, an immediate purchase requires an estimated annual household income of ${formatCurrency(incomeNow)}. A delayed purchase requires an estimated annual household income of ${formatCurrency(incomeLater)} based on the projected future price and interest rate.`;

            const summaryBox = document.getElementById('summaryBoxBlock');
            const totalTextEl = document.getElementById('txtTotalCostOfWaiting');
            const titleEl = document.getElementById('txtSummaryTitle');
            const subtitleEl = document.getElementById('txtSummarySubtitle');

            if (absoluteFinancialLoss > 0) {
                summaryBox.classList.remove('advantage-waiting');
                totalTextEl.classList.remove('advantage-waiting');
                titleEl.textContent = "Cost of Waiting Summary";
                subtitleEl.textContent = "Based on these inputs, a purchase today results in a lower total calculated financial outlay over this timeframe. The difference between the two tracks is:";
                totalTextEl.textContent = formatCurrency(absoluteFinancialLoss);
                document.getElementById('txtCoachConclusion').textContent = `Historical data indicates that home price growth and rent outlays frequently combine to create a higher total cost if a purchase is delayed. Securing the home at today's price sets your baseline cost and begins reducing your loan balance right away. If interest rates drop down the road, homeowners can explore refinancing options to lower their regular monthly payments without needing to catch up to a higher purchase price.`;
            } else {
                summaryBox.classList.add('advantage-waiting');
                totalTextEl.classList.add('advantage-waiting');
                titleEl.textContent = "Cost of Waiting Summary";
                subtitleEl.textContent = "Based on these inputs, a delayed purchase results in a lower total calculated financial outlay over this timeframe. The difference between the two tracks is:";
                totalTextEl.textContent = formatCurrency(Math.abs(absoluteFinancialLoss));
                document.getElementById('txtCoachConclusion').textContent = `In this scenario, delaying the purchase aligns with a lower total calculated outlay. Over the next ${waitYears} ${waitYears === 1 ? 'year' : 'years'}, the financial benefit of a lower projected interest rate and an increased down payment outweighs both the total rent paid while waiting and the projected home price growth of ${formatCurrency(priceIncreasePenalty)}.`;
            }

            document.getElementById('resultsWrapper').style.display = 'block';
            document.getElementById('resultsWrapper').scrollIntoView({ behavior: 'smooth' });
        };

        function calculateAmortization(principal, annualRate) {
            if (principal <= 0) return 0;
            const monthlyRate = (annualRate / 100) / 12;
            const totalPayments = 360;
            if (monthlyRate === 0) return principal / totalPayments;
            return principal * (monthlyRate * Math.pow(1 + monthlyRate, totalPayments)) / (Math.pow(1 + monthlyRate, totalPayments) - 1);
        }
    });
</script>