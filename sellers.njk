<style>
    /* Mobile Fix for Stats Container */
    .stats-mobile-fix {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 3rem;
        text-align: center;
    }
    @media (max-width: 600px) {
        .stats-mobile-fix {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
    }
    @media (min-width: 768px) {
        .stats-mobile-fix {
            display: flex;
            justify-content: center;
            gap: 4rem;
        }
    }

    /* Inline CTA Button Row */
    .inline-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin: 2.5rem 0;
        flex-wrap: wrap;
    }

    /* Responsive Images */
    .section-image {
        width: 100%;
        height: auto;
        border-radius: 12px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        object-fit: cover;
    }
    .hero-image { max-height: 400px; }
    .sign-image { max-height: 300px; width: auto; max-width: 100%; display: block; margin-left: auto; margin-right: auto; }

    /* Rocket LO Mini Profile */
    .lo-profile {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--premier-beige);
        text-align: left;
    }
    .lo-img {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--redfin-red);
    }
    .lo-info { font-size: 0.9rem; line-height: 1.3; }
    .lo-info strong { color: var(--premier-charcoal); font-size: 1rem; }
    .lo-info a { color: var(--redfin-red); font-weight: bold; text-decoration: none; }

    /* Refined Architectural Layout: Centered Seller Incentive Container Box */
    .universal-incentives-box {
        background-color: #FFF5F5;
        border: 2px dashed var(--redfin-red);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        margin: 2rem auto 3rem auto;
        text-align: center;
        max-width: 900px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }
    .universal-incentives-box h3 {
        color: var(--redfin-red);
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
    }
    .universal-incentives-box p.box-intro {
        font-size: 0.95rem;
        opacity: 0.85;
        max-width: 750px;
        margin: 0 auto 1.5rem auto;
        line-height: 1.5;
        color: var(--premier-charcoal);
    }
    .scenarios-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    @media (min-width: 768px) {
        .scenarios-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
    .scenario-card {
        background-color: var(--white);
        border-top: 4px solid var(--premier-charcoal);
        padding: 1.5rem;
        border-radius: 8px;
        text-align: left;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }
    .scenario-card.loyal {
        border-top-color: var(--redfin-red);
    }
    .scenario-card h4 {
        font-size: 1.05rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: var(--premier-charcoal);
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
    .scenario-value {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--redfin-red);
        margin-bottom: 0.5rem;
    }
    .scenario-card p {
        font-size: 0.9rem;
        line-height: 1.4;
        opacity: 0.9;
        margin: 0;
        color: #444;
    }
</style>

