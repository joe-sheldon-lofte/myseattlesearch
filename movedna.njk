<script>
    document.addEventListener('DOMContentLoaded', () => {
        const tabs = document.querySelectorAll('.dna-tab-btn');
        const contents = document.querySelectorAll('.dna-content-section');

        tabs.forEach(tab => {
            tab.addEventListener('click', function() {
                tabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');

                const targetId = this.getAttribute('data-target');
                contents.forEach(section => {
                    if (section.id === targetId) {
                        section.classList.add('active');
                    } else {
                        section.classList.remove('active');
                    }
                });
            });
        });
    });

    function launchQuizModule(quizId) {
        const choiceCards = document.getElementById('quiz-choice-cards');
        const viewport = document.getElementById('quiz-engine-viewport');
        const mount = document.getElementById('quiz-engine-mount');

        choiceCards.style.display = 'none';
        mount.innerHTML = '';

        const newEngineTag = document.createElement('quiz-engine');
        newEngineTag.setAttribute('quiz-id', quizId);
        mount.appendChild(newEngineTag);

        viewport.style.display = 'block';
        viewport.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetQuizWorkflowPanel() {
        const choiceCards = document.getElementById('quiz-choice-cards');
        const viewport = document.getElementById('quiz-engine-viewport');
        const mount = document.getElementById('quiz-engine-mount');

        viewport.style.display = 'none';
        mount.innerHTML = '';
        choiceCards.style.display = '';
    }
</script>