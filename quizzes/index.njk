---
layout: base.njk
title: "Quiz Catalog | Joe Sheldon"
permalink: /quizzes/
---

<div style="max-width:900px; margin:4rem auto; padding:0 1.5rem; min-height:60vh;">
    <div style="text-align:center; margin-bottom:3rem;">
        <h1 style="font-size:2.5rem; font-weight:800; margin:0; color: var(--card-accent-color);">Quiz Hub</h1>
        <p style="color: var(--premier-charcoal); opacity: 0.8; font-size:1.1rem; margin-top:0.5rem;">Pick a quiz and get started!</p>
    </div>
    <div id="catalog-mount" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(320px, 1fr)); gap:2rem;"></div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const mount = document.getElementById('catalog-mount');
        try {
            const res = await fetch('/data/quizzes.json');
            const db = await res.json();
            const today = new Date().setHours(0,0,0,0);
            
            const quizArray = Object.values(db);
            quizArray.sort((a, b) => (b.rank || 0) - (a.rank || 0));

            let html = '';
            let validCount = 0;

            for (const quiz of quizArray) {
                if (quiz.showInCatalog !== "Yes") continue; 
                if (quiz.startDate && today < new Date(quiz.startDate + "T00:00:00")) continue;
                if (quiz.endDate && today > new Date(quiz.endDate + "T00:00:00")) continue;

                validCount++;
                
                // Dynamic Card Image Header Template using CSS custom properties
                const cardImageHtml = quiz.quizImage 
                    ? `<img src="${quiz.quizImage}" alt="${quiz.webTitle}" style="width:100%; height:180px; object-fit:cover; border-radius:8px; margin-bottom:1.25rem; display:block;">` 
                    : '';

                html += `
                    <div style="background: white; border:1px solid var(--premier-beige); border-top:5px solid var(--card-accent-color); border-radius:12px; padding:2rem; display:flex; flex-direction:column; justify-content:space-between;">
                        <div>
                            ${cardImageHtml}
                            <h3 style="margin:0 0 0.5rem 0; font-size:1.35rem; font-weight:700; color: var(--premier-charcoal);">${quiz.webTitle}</h3>
                            <p style="color: var(--premier-charcoal); opacity: 0.8; font-size:0.95rem; line-height:1.5; margin-bottom:1.5rem;">${quiz.introText}</p>
                        </div>
                        <a href="/quizzes/viewport/?id=${quiz.id}" class="btn btn-primary" style="text-align:center; font-weight:bold; text-decoration:none; background-color: var(--card-accent-color); border-color: var(--card-accent-color); color: white;">Take the Test</a>
                    </div>`;
            }
            mount.innerHTML = html || `<p style="text-align:center; width:100%; color: var(--premier-charcoal); opacity: 0.7;">No public campaigns active right now.</p>`;
        } catch (e) { 
            mount.innerHTML = '<p style="text-align:center; width:100%; color: var(--card-accent-color);">Error loading catalog.</p>'; 
        }
    });
</script>