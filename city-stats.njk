                            <div style="margin-bottom: 1rem;">
                                <div style="display:flex; justify-content:space-between; font-size:0.85rem; font-weight:800; margin-bottom:0.25rem; color:var(--premier-charcoal);">
                                    <span>📖 ELA PROFICIENCY</span>
                                    <span id="txtElaScore">--</span>
                                </div>
                                <div style="background:var(--premier-beige); height:8px; border-radius:4px; width:100%; position:relative;">
                                    <div id="barElaScore" style="background: #4A90E2; height:100%; width:0%; border-radius:4px; transition: width 0.6s ease;"></div>
                                </div>
                            </div>
                            <span style="font-size: 0.8rem; text-transform: uppercase; color: var(--premier-charcoal); opacity: 0.8; font-weight: 800; display:block; line-height:1.3;">Compared against State Baselines (<span id="lblStateBaselines">Math -- / ELA --</span>)</span>
                        </div>
                        <div id="schoolDataSuppressed" style="display: none; padding: 1rem 0;">
                            <div class="walkscore-container" style="margin-bottom: 1rem;">
                                <div class="score-badge suppressed-badge">N/A</div>
