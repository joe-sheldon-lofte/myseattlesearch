                                    <div class="score-desc">Data Sealed</div>
                                    <div class="score-sub">Privacy Protection</div>
                                </div>
                            </div>
                            <p style="font-size: 0.95rem; color: var(--premier-charcoal); line-height: 1.5; margin: 0;">ℹ️ <span id="txtSuppressionStatus">Data not available</span>. State testing scores are legally sealed for very small student populations to fully protect student privacy.</p>
                        </div>
                    </div>
                    <a href="https://www.greatschools.org/" id="greatSchoolsLink" target="_blank" class="card-action-btn" style="margin-top: 1.5rem;">View detailed ratings and boundaries on GreatSchools &rarr;</a>
                </div>

                <div class="metric-card" id="climateComfortCard">
                    <div>
                        <h3>Climate & Microclimate Profile</h3>
                        <div class="walkscore-container" style="margin-bottom: 0.75rem;">
                            <div class="score-badge" id="climateComfortScore" style="background: #F5A623;">--</div>
                            <div class="score-info">
                                <div class="score-desc" id="climateStationLabel">Loading NOAA Profile...</div>
                                <div class="score-sub">Comfort Index Score</div>
                            </div>
                        </div>
                        <p id="climateSummaryText" style="font-size: 0.95rem; color: var(--premier-charcoal); opacity: 0.9; line-height: 1.4; margin: 0.5rem 0 1rem 0; font-style: italic;">Awaiting coordinates sync...</p>
                        <div class="climate-metrics-list">
                            <div class="climate-mini-item">
                                <span>☀️ Summer High</span>
                                <strong id="txtSummerHigh">--</strong>
                            </div>
                            <div class="climate-mini-item">
                                <span>❄️ Winter Low</span>
                                <strong id="txtWinterLow">--</strong>
                            </div>
                            <div class="climate-mini-item">
                                <span>🌧️ Annual Rain</span>
                                <strong id="txtAnnualRain">--</strong>
                            </div>
                            <div class="climate-mini-item">
                                <span>🌤️ Sunny Days</span>
                                <strong id="txtSunnyDays">--</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="metric-card" id="publicSafetyCard">
                    <div>
                        <h3>Emergency Services</h3>
                        
                        <div style="margin-bottom: 1.5rem;">
                            <span class="safety-subhead">CRIME & PUBLIC SAFETY</span>
                            <div style="font-size: 0.95rem; font-weight: 700; margin: 0 0 0.75rem 0; color: var(--premier-charcoal);" id="safetyAgencyHeader">Local Public Safety Status</div>
                            
                            <div id="crimeNoticeBadge" class="custom-notice-block" style="border-left-color: var(--card-accent-color); margin-bottom: 1rem; background: var(--dynamic-bg-highlight);">
                                ℹ️ Official FBI NIBRS data is currently pending or unmapped for this municipality. View live local community logs via the button below.
                            </div>

                            <div id="activeCrimeStatsContainer" style="display:none; margin-bottom: 1rem;">
                                <div style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                                    <div>
                                        <span style="font-size:0.8rem; color:var(--premier-charcoal); opacity: 0.8; font-weight:800; display:block;">💥 VIOLENT CRIMES RATE</span>
                                        <strong id="txtViolentRate" style="font-size:1.4rem; color:var(--premier-charcoal); font-weight:800;">--</strong>
                                        <span style="font-size:0.8rem; color:var(--premier-charcoal); opacity: 0.8; display:block; font-weight: 600;">per 1,000 residents</span>
                                    </div>
                                    <div>
                                        <span style="font-size:0.8rem; color:var(--premier-charcoal); opacity: 0.8; font-weight:800; display:block;">🏡 PROPERTY CRIMES RATE</span>
                                        <strong id="txtPropertyRate" style="font-size:1.4rem; color:var(--premier-charcoal); font-weight:800;">--</strong>
                                        <span style="font-size:0.8rem; color:var(--premier-charcoal); opacity: 0.8; display:block; font-weight: 600;">per 1,000 residents</span>
                                    </div>
                                </div>
                                <span class="custom-info-toggle" onclick="document.getElementById('crimeExplanation').classList.toggle('active')">What do these numbers mean?</span>
                                <div id="crimeExplanation" class="psai-dropdown">
                                    <strong>What 'Per 1,000 Neighbors' Means:</strong> This gives us a fair way to compare a small town to a major city. For example, a property crime rate of 20.0 means that for every 1,000 people living in this city, about 20 property reports (like theft or vandalism) are filed each year.<br><br><strong>The Categories:</strong><br>• <em>Violent Crime:</em> Includes safety incidents involving people, such as assault or robbery.<br>• <em>Property Crime:</em> Includes incidents involving property, such as break-ins, car thefts, or vandalism.
                                </div>
                            </div>
                            <a href="#" id="spotCrimeLink" target="_blank" class="card-action-btn" style="margin-top: 0; width: 100%;">View additional local crime data on SpotCrime &rarr;</a>
                        </div>

                        <div style="border-top: 2px solid var(--premier-beige); padding-top: 1rem; margin-bottom: 1.5rem;">
                            <span class="safety-subhead">🚒 FIRE & RISK PROTECTION</span>
                            <div style="font-size: 0.95rem; font-weight: 700; color: var(--premier-charcoal); margin-top: 0.25rem;" id="txtFireAgency">Loading Responder Profile...</div>
                            <div id="fireBadgeContainer"></div>
                        </div>

                        <div style="border-top: 2px solid var(--premier-beige); padding-top: 1rem;">
                            <span class="safety-subhead">🏥 EMERGENCY MEDICAL</span>
                            <div style="font-size: 0.95rem; color: var(--premier-charcoal); margin-top: 0.25rem;" id="hospitalProximityContainer">
                                Loading proximity calculations...
                            </div>
                        </div>
                    </div>
                </div>

                <div class="metric-card" id="surveillanceCard">
                    <div>
                        <h3>Municipal Surveillance Profile</h3>
                        <div class="walkscore-container" style="margin-bottom: 0.75rem;">
                            <div class="score-badge" id="surveillanceScoreBadge" style="background: #1F4E5B;">--</div>
                            <div class="score-info">
                                <div class="score-desc" id="surveillanceAgencyLabel">Loading infrastructure density...</div>
                                <div class="score-sub">Surveillance Score (1-100)</div>
                            </div>
                        </div>
                        <div id="surveillanceNoticeBlock" class="custom-notice-block" style="border-left-color: #F5A623; background: var(--dynamic-bg-highlight); margin-bottom: 1rem;">
                            ℹ️ <strong>Data Note:</strong> Surveillance data is currently not available for this city.
                        </div>
                        <div id="surveillanceActiveData" style="display: none;">
                            <div class="surveillance-metrics-list">
                                <div class="surv-mini-item">
                                    <span>🚗 ALPR Cams</span>
                                    <strong id="txtAlprCount">--</strong>
                                </div>
                                <div class="surv-mini-item">
                                    <span>🚦 Traffic Cams</span>
                                    <strong id="txtTrafficCount">--</strong>
                                </div>
                                <div class="surv-mini-item">
                                    <span>📹 General CCTV</span>
                                    <strong id="txtCctvCount">--</strong>
                                </div>
                                <div class="surv-mini-item">
                                    <span>💻 Data Platforms</span>
                                    <strong id="txtSoftwareCount">--</strong>
                                </div>
                            </div>
                            <span class="custom-info-toggle" onclick="document.getElementById('surveillanceExplanation').classList.toggle('active')">What do these categories mean?</span>
                            <div id="surveillanceExplanation" class="psai-dropdown">
                                <strong>License Plate Readers (ALPR):</strong> Local cameras that scan license plates to help track vehicle locations.<br><br><strong>Traffic Cameras:</strong> Automated speed and red-light enforcement cameras (this doesn't include normal state highway traffic flow cameras).<br><br><strong>Public Space Cameras (CCTV):</strong> Standard public security or property monitoring camera networks.<br><br><strong>Software Systems:</strong> Tech platforms or tracking systems used by local agencies to monitor public safety data.
                            </div>
                        </div>
                    </div>
                    <span style="font-size: 0.85rem; color: var(--premier-charcoal); opacity: 0.8; font-weight: 700; display: block; margin-top: 1.25rem; line-height: 1.4;">Data provided by Deflock via OpenStreetMap and the Atlas of Surveillance.</span>
                </div>
            </div>
        </section>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

    const snapshotPath = '/data/hourly_market.json';
    const redfinPath = '/data/redfin_stats.json';
    const infosparksPath = '/data/infosparks_stats.json';
    const mobilityPath = '/data/walk_transit_bike_scores.json';
    const schoolPath = '/data/school_ratings.json';
    const crimePath = '/data/crime_stats.json';
    const climatePath = '/data/climate_comfort.json';
    const emergencyPath = '/data/public_safety_emergency.json';
    const surveillancePath = '/data/surveillance_stats.json';
    
    const currentCity = "{{ city.City }}";
    const isNorthSound = {{ 'true' if city['North Sound'] | lower == 'x' else 'false' }};

    let dataStore = { 
        snapshot: [], historical: [], redfin: [], infosparks: {}, 
        mobility: {}, schools: {}, crime: {}, climate: {}, emergency: {}, surveillance: {} 
    };
    
    let cityDirData = {
        policeName: "{{ city['Police Department Name'] }}",
        policeCrimePage: "{{ city['Police Department Crime Page'] }}"
    };
    
    let velocityChartInstance = null;
    let macroPriceChartInstance = null; 
    let macroSalesChartInstance = null;
    let macroDOMChartInstance = null;
    let macroShowsChartInstance = null;

    const cleanNum = (str) => {
        if (str === null || str === undefined || str === 'NaN') return 0;
        return parseFloat((str).toString().replace(/[^0-9.-]+/g, "")) || 0;
    };
    const formatCurrency = (num) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    const formatPercent = (num) => (num * 100).toFixed(1) + '%';

    const getRowValueForCity = (row, city) => {
        if (!row || !city) return null;
        const target = city.toLowerCase().trim();
        for (let key in row) {
            if (key.toLowerCase().trim() === target) return row[key];
        }
        return null;
    };

    const getTopOfHour = () => {
        const now = new Date();
        now.setMinutes(0, 0, 0);
        return now.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
    };

    const getThirdBusinessDay = () => {
        const now = new Date();
        let count = 0;
        let day = 1;
        while (count < 3) {
            let d = new Date(now.getFullYear(), now.getMonth(), day);
            let dayOfWeek = d.getDay();
            if (dayOfWeek !== 0 && dayOfWeek !== 6) count++;
            if (count < 3) day++;
        }
        return new Date(now.getFullYear(), now.getMonth(), day).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    };

    const fetchJSON = async (path) => {
        try { 
            const res = await fetch(path);
            if (!res.ok) return null;
            const rawText = await res.text();
            const cleanedText = rawText.replace(/:\s*NaN/g, ": null");
            return JSON.parse(cleanedText); 
        } 
        catch (e) { return null; }
    };

    Promise.all([
        fetchJSON(snapshotPath),
        fetchJSON(redfinPath),
        fetchJSON(infosparksPath),
        fetchJSON(mobilityPath),
        fetchJSON(schoolPath),
        fetchJSON(crimePath),
        fetchJSON(climatePath),
        fetchJSON(emergencyPath),
        fetchJSON(surveillancePath)
    ]).then(values => {
        dataStore.snapshot = values[0] || [];
        dataStore.historical = [];
        let rf = values[1];
        dataStore.redfin = Array.isArray(rf) ? rf : (rf && rf.records ? rf.records : []);
        let is = values[2];
        dataStore.infosparks = is && is.feeds ? is.feeds : (is || {});
        dataStore.mobility = values[3] || {};
        dataStore.schools = values[4] || {};
        dataStore.crime = values[5] || {};
        dataStore.climate = values[6] || {};
        dataStore.emergency = values[7] || {};
        dataStore.surveillance = values[8] || {};
        
        updateDashboard();
    }).catch(err => {
        console.error("Critical loading error:", err);
    });

    const updateDashboard = () => {
        document.getElementById('dashboardContent').style.display = 'block';
        setTimeout(() => document.getElementById('dashboardContent').style.opacity = '1', 50);
        
        if (isNorthSound && document.getElementById('stampRealTime')) {
            document.getElementById('stampRealTime').textContent = 'Updated Hourly • Last Update: Today at ' + getTopOfHour();
            renderRealTime();
        }
        
        document.getElementById('stampMacro').textContent = 'Updated Monthly • Last Update: ' + getThirdBusinessDay();

        const currentSupplyValue = renderVelocity();
        renderMacro(currentSupplyValue);
        renderMobilityMetrics();
        renderSchoolMetrics();
        renderClimateMetrics();
        renderPublicSafetyMetrics();
        renderSurveillanceMetrics();
    };

    const renderRealTime = () => {
        const citySnap = dataStore.snapshot.find(row => row.City && row.City.trim() === currentCity) || {};
        document.getElementById('valNewListings').textContent = cleanNum(citySnap['New Listings']);
        document.getElementById('valPending').textContent = cleanNum(citySnap['Pending']);
        document.getElementById('valSold').textContent = cleanNum(citySnap['Sold']);
        document.getElementById('valAvgPrice').textContent = formatCurrency(cleanNum(citySnap['Avg New Price']));

        const cityHistory = dataStore.historical
            .filter(row => row.City && row.City.trim() === currentCity && row.Timestamp)
            .sort((a, b) => new Date(a.Timestamp) - new Date(b.Timestamp));

        const labels = cityHistory.map(row => {
            const d = new Date(row.Timestamp);
            return isNaN(d.getTime()) ? '' : `${d.getMonth()+1}/${d.getDate()}`;
        }).filter(l => l !== '');
        
        if (velocityChartInstance) velocityChartInstance.destroy();
        const ctxVel = document.getElementById('velocityChart').getContext('2d');
        velocityChartInstance = new Chart(ctxVel, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { label: 'New Listings', data: cityHistory.map(row => cleanNum(row['New Listings'])), borderColor: '#3D3935', tension: 0.3 },
                    { label: 'Pending', data: cityHistory.map(row => cleanNum(row['Pending'])), borderColor: 'var(--card-accent-color)', tension: 0.3 }
                ]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
    };

    const renderVelocity = () => {
        const rfData = dataStore.redfin
            .filter(r => r.city && r.city.toLowerCase().trim() === currentCity.toLowerCase().trim())
            .sort((a, b) => new Date(b.period_begin) - new Date(a.period_begin)); 

        let activeSupply = 0;

        if (rfData.length > 0) {
            const latest = rfData[0];
            activeSupply = cleanNum(latest.months_of_supply);

            const rfDate = new Date(latest.period_end || latest.period_begin);
            if(!isNaN(rfDate)) {
                document.getElementById('stampVelocity').textContent = 'Updated Monthly • Last Update: ' + rfDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
            }
            
            document.getElementById('valDOM').textContent = latest.median_dom !== null && !isNaN(latest.median_dom) ? latest.median_dom : '--';
            document.getElementById('valAboveList').textContent = latest.sold_above_list !== null && !isNaN(latest.sold_above_list) ? formatPercent(cleanNum(latest.sold_above_list)) : '--';
            document.getElementById('valUrgency').textContent = latest.off_market_in_two_weeks !== null && !isNaN(latest.off_market_in_two_weeks) ? formatPercent(cleanNum(latest.off_market_in_two_weeks)) : '--';
            
            const frictionVal = latest.market_friction_index;
            const valFrictionEl = document.getElementById('valFriction');

            if (frictionVal !== undefined && frictionVal !== null && !isNaN(frictionVal)) {
                valFrictionEl.textContent = Math.round(frictionVal);
                let colorClass = '#3D3935'; 
                if (frictionVal >= 80) colorClass = 'var(--card-accent-color)';
                else if (frictionVal >= 60) colorClass = 'var(--card-accent-color)';
                else if (frictionVal >= 40) colorClass = '#F5A623';
                else if (frictionVal >= 20) colorClass = '#4A90E2';
                else colorClass = '#1F4E5B';
                valFrictionEl.style.color = colorClass;
            } else {
                valFrictionEl.textContent = '--';
                valFrictionEl.style.color = 'var(--premier-charcoal)';
            }
        } else {
            document.getElementById('stampVelocity').textContent = 'Updated Monthly • Awaiting Data Sync';
            document.getElementById('valDOM').textContent = '--';
            document.getElementById('valAboveList').textContent = '--';
            document.getElementById('valUrgency').textContent = '--';
            document.getElementById('valFriction').textContent = '--';
            document.getElementById('valFriction').style.color = 'var(--premier-charcoal)';
        }
        return activeSupply;
    };

    const extractInfosparksData = (metricSuffix, city) => {
        const target = city.toLowerCase().trim();
        for (let feedKey in dataStore.infosparks) {
            if (feedKey.toLowerCase().includes(metricSuffix.toLowerCase())) {
                const feed = dataStore.infosparks[feedKey];
                let rows = Array.isArray(feed) ? feed : (feed.data || []);
                
                if (rows.length > 0) {
                    const validRow = rows.find(r => r.Date && !String(r.Date).includes("All data from"));
                    if (validRow) {
                        const hasCity = Object.keys(validRow).some(k => k.toLowerCase().trim() === target);
                        if (hasCity) {
                            return rows.filter(row => {
                                if (!row || !row.Date || String(row.Date).includes("All data from")) return false;
                                let val = getRowValueForCity(row, city);
                                return val !== null && val !== undefined && val !== 'NaN' && !Number.isNaN(val);
                            }).map(row => {
                                return { label: row.Date, val: cleanNum(getRowValueForCity(row, city)) };
                            }).slice(-12);
                        }
                    }
                }
            }
        }
        return []; 
    };

    const renderMacro = (fallbackSupply) => {
        const priceTimeline = extractInfosparksData('median_sale_price', currentCity);
        const salesTimeline = extractInfosparksData('closed_sales', currentCity);
        const domTimeline = extractInfosparksData('average_days_on_market', currentCity);
        const showsTimeline = extractInfosparksData('shows_per_listing', currentCity);
        const supplyTimeline = extractInfosparksData('months_supply_closed', currentCity);

        let currentSupply = fallbackSupply;
        if (supplyTimeline.length > 0) {
            currentSupply = supplyTimeline[supplyTimeline.length - 1].val;
        }

        const clampedSupply = Math.max(0, Math.min(6, currentSupply));
        const percentagePosition = (clampedSupply / 6) * 100;
        document.getElementById('climateNeedle').style.left = `calc(${percentagePosition}% - 2px)`;

        let climateVibe = "Balanced Market";
        if (currentSupply <= 1.25) climateVibe = "Hot Seller's Market";
        else if (currentSupply <= 2.4) climateVibe = "Seller's Market";
        else if (currentSupply <= 3.5) climateVibe = "Balanced Market";
        else if (currentSupply <= 4.74) climateVibe = "Buyer's Market";
        else climateVibe = "Hot Buyer's Market";

        document.getElementById('climateLabelText').textContent = `${climateVibe} (${currentSupply.toFixed(2)} Months Supply)`;

        if (macroPriceChartInstance) macroPriceChartInstance.destroy();
        macroPriceChartInstance = new Chart(document.getElementById('macroPriceChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: priceTimeline.map(t => t.label),
                datasets: [{ label: 'Median Price', data: priceTimeline.map(t => t.val), borderColor: '#3D3935', fill: true, backgroundColor: 'rgba(61, 57, 53, 0.05)', tension: 0.2 }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        if (macroSalesChartInstance) macroSalesChartInstance.destroy();
        macroSalesChartInstance = new Chart(document.getElementById('macroSalesChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: salesTimeline.map(t => t.label),
                datasets: [{ label: 'Closed Sales', data: salesTimeline.map(t => t.val), backgroundColor: '#a0a0a0' }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        if (macroDOMChartInstance) macroDOMChartInstance.destroy();
        macroDOMChartInstance = new Chart(document.getElementById('macroDOMChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: domTimeline.map(t => t.label),
                datasets: [{ label: 'Avg DOM', data: domTimeline.map(t => t.val), borderColor: 'var(--card-accent-color)', tension: 0.2, fill: false }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        if (macroShowsChartInstance) macroShowsChartInstance.destroy();
        macroShowsChartInstance = new Chart(document.getElementById('macroShowsChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: showsTimeline.map(t => t.label),
                datasets: [{ label: 'Buyer Showings Per Listing', data: showsTimeline.map(t => t.val), borderColor: '#4A90E2', tension: 0.2, fill: false }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });
    };

    const renderMobilityMetrics = () => {
        let activeScores = null;
        const targetCity = currentCity.trim().toLowerCase();
        const safeTarget = targetCity.replace(/[^a-z0-9]/g, '');

        if (dataStore.mobility) {
            if (Array.isArray(dataStore.mobility)) {
                activeScores = dataStore.mobility.find(item => {
                    const name = (item.City || item.city || item.Name || item.name || '').toLowerCase().replace(/[^a-z0-9]/g, '');
                    return name === safeTarget;
                });
            } else {
                const matchedKey = Object.keys(dataStore.mobility).find(key => 
                    key.toLowerCase().replace(/[^a-z0-9]/g, '') === safeTarget
                );
                if (matchedKey) activeScores = dataStore.mobility[matchedKey];
            }
        }
        
        const getScore = (obj, keys) => {
            for (let k of keys) {
                if (obj[k] !== undefined && obj[k] !== null) return obj[k];
            }
            return '--';
        };
        
        if (activeScores) {
            document.getElementById('cityWalkScore').textContent = getScore(activeScores, ['walk_score', 'walkScore', 'Walk Score', 'walk']);
            const walkDesc = getScore(activeScores, ['description', 'walk_description', 'walkDescription']);
            document.getElementById('cityWalkDesc').textContent = walkDesc === '--' ? 'Data Available' : walkDesc;
            
            document.getElementById('cityTransitScore').textContent = getScore(activeScores, ['transit_score', 'transitScore', 'Transit Score', 'transit']);
            const transDesc = getScore(activeScores, ['transit_description', 'transitDescription']);
            document.getElementById('cityTransitDesc').textContent = transDesc === '--' ? 'Data Available' : transDesc;
            
            document.getElementById('cityBikeScore').textContent = getScore(activeScores, ['bike_score', 'bikeScore', 'Bike Score', 'bike']);
            const bikeDesc = getScore(activeScores, ['bike_description', 'bikeDescription']);
            document.getElementById('cityBikeDesc').textContent = bikeDesc === '--' ? 'Data Available' : bikeDesc;
            
            document.getElementById('walkScoreLink').href = activeScores.link || `https://www.walkscore.com/WA/${encodeURIComponent(currentCity.trim())}`;
            document.getElementById('walkScoreLink').style.display = 'inline-flex';
        } else {
            document.getElementById('cityWalkScore').textContent = '--';
            document.getElementById('cityTransitScore').textContent = '--';
            document.getElementById('cityBikeScore').textContent = '--';
            document.getElementById('cityWalkDesc').textContent = 'Metrics normalizing...';
            document.getElementById('cityTransitDesc').textContent = 'Awaiting classification';
            document.getElementById('cityBikeDesc').textContent = 'Awaiting classification';
            document.getElementById('walkScoreLink').style.display = 'none';
        }
    };

    const renderSchoolMetrics = () => {
        const targetCity = currentCity.trim();
        let districtData = null;
        
        if (dataStore.schools) {
            const matchedKey = Object.keys(dataStore.schools).find(key => key.toLowerCase() === targetCity.toLowerCase());
            if (matchedKey) districtData = dataStore.schools[matchedKey];
        }

        const activeContainer = document.getElementById('schoolDataActive');
        const suppressedContainer = document.getElementById('schoolDataSuppressed');

        if (districtData) {
            document.getElementById('schoolDistrictName').textContent = districtData.district_name || 'Local Public District';
            
            if (districtData.custom_score === null) {
                activeContainer.style.display = 'none';
                suppressedContainer.style.display = 'block';
                document.getElementById('txtSuppressionStatus').textContent = districtData.status || "Data suppressed";
            } else {
                activeContainer.style.display = 'block';
                suppressedContainer.style.display = 'none';

                const scoreVal = districtData.custom_score !== undefined ? districtData.custom_score.toFixed(1) : '--';
                document.getElementById('districtCustomScore').textContent = scoreVal;
                
                let customVibe = "Average Performance";
                if (districtData.custom_score >= 8.0) customVibe = "Exceptional System";
                else if (districtData.custom_score >= 6.0) customVibe = "Strong Academic Profile";
                else if (districtData.custom_score >= 4.0) customVibe = "Solid Baseline Academics";
                else customVibe = "Needs Local District Adjustments";
                document.getElementById('districtCustomVibe').textContent = customVibe;

                const mathPct = districtData.district_math_proficiency || 0;
                document.getElementById('txtMathScore').textContent = mathPct.toFixed(1) + '%';
                document.getElementById('barMathScore').style.width = `${Math.min(100, mathPct)}%`;

                const elaPct = districtData.district_ela_proficiency || 0;
                document.getElementById('txtElaScore').textContent = elaPct.toFixed(1) + '%';
                document.getElementById('barElaScore').style.width = `${Math.min(100, elaPct)}%`;

                const baseMath = districtData.state_math_baseline !== undefined ? districtData.state_math_baseline.toFixed(0) + '%' : '--';
                const baseEla = districtData.state_ela_baseline !== undefined ? districtData.state_ela_baseline.toFixed(0) + '%' : '--';
                document.getElementById('lblStateBaselines').textContent = `Math: ${baseMath} / ELA: ${baseEla}`;
            }

            const citySlug = targetCity.toLowerCase().replace(/\s+/g, '-');
            document.getElementById('greatSchoolsLink').href = `https://www.greatschools.org/washington/${citySlug}/`;
        } else {
            document.getElementById('schoolDistrictName').textContent = 'District Profile Unavailable';
            activeContainer.style.display = 'block';
            suppressedContainer.style.display = 'none';
            document.getElementById('districtCustomScore').textContent = '--';
            document.getElementById('districtCustomVibe').textContent = 'Metrics currently normalizing...';
            document.getElementById('txtMathScore').textContent = '--';
            document.getElementById('barMathScore').style.width = '0%';
            document.getElementById('txtElaScore').textContent = '--';
            document.getElementById('barElaScore').style.width = '0%';
            document.getElementById('lblStateBaselines').textContent = 'Math -- / ELA --';
            document.getElementById('greatSchoolsLink').href = "https://www.greatschools.org/";
        }
    };

    const renderClimateMetrics = () => {
        const targetCity = currentCity.trim();
        let climateData = null;
        
        if (dataStore.climate) {
            const matchedKey = Object.keys(dataStore.climate).find(key => key.toLowerCase() === targetCity.toLowerCase());
            if (matchedKey) climateData = dataStore.climate[matchedKey];
        }

        if (climateData) {
            const score = climateData.comfort_index_score;
            document.getElementById('climateComfortScore').textContent = score !== null && score !== undefined ? score.toFixed(1) : '--';
            document.getElementById('climateStationLabel').textContent = climateData.assigned_weather_station || 'Assigned NOAA Node';
            document.getElementById('climateSummaryText').textContent = climateData.microclimate_summary || 'Microclimate narrative configuration pending.';
            
            const m = climateData.metrics || {};
            document.getElementById('txtSummerHigh').textContent = m.average_summer_high_f !== undefined && m.average_summer_high_f !== null ? `${m.average_summer_high_f}°F` : '--';
            document.getElementById('txtWinterLow').textContent = m.average_winter_low_f !== undefined && m.average_winter_low_f !== null ? `${m.average_winter_low_f}°F` : '--';
            document.getElementById('txtAnnualRain').textContent = m.annual_rainfall_inches !== undefined && m.annual_rainfall_inches !== null ? `${m.annual_rainfall_inches}"` : '--';
            document.getElementById('txtSunnyDays').textContent = m.annual_sunny_days !== undefined && m.annual_sunny_days !== null ? m.annual_sunny_days : '--';
        } else {
            document.getElementById('climateComfortScore').textContent = '--';
            document.getElementById('climateStationLabel').textContent = 'Station Sync Pending';
            document.getElementById('climateSummaryText').textContent = 'Environmental indicators currently normalizing across tracking grids.';
            document.getElementById('txtSummerHigh').textContent = '--';
            document.getElementById('txtWinterLow').textContent = '--';
            document.getElementById('txtAnnualRain').textContent = '--';
            document.getElementById('txtSunnyDays').textContent = '--';
        }
    };

    const renderPublicSafetyMetrics = () => {
        const targetCity = currentCity.trim();
        const cityKey = targetCity.toLowerCase();
        
        let crimeData = null;
        if (dataStore.crime) {
            const matchedCrimeKey = Object.keys(dataStore.crime).find(key => key.toLowerCase() === cityKey);
            if (matchedCrimeKey) crimeData = dataStore.crime[matchedCrimeKey];
        }

        let safetyData = null;
        if (dataStore.emergency) {
            const matchedSafetyKey = Object.keys(dataStore.emergency).find(key => key.toLowerCase() === cityKey);
            if (matchedSafetyKey) safetyData = dataStore.emergency[matchedSafetyKey];
        }

        const noticeBadge = document.getElementById('crimeNoticeBadge');
        const statsContainer = document.getElementById('activeCrimeStatsContainer');
        const ctaBtn = document.getElementById('spotCrimeLink');

        let crimeLink = cityDirData.policeCrimePage;
        let isSpotCrime = crimeLink ? crimeLink.toLowerCase().includes('spotcrime') : true;
        let crimeSource = isSpotCrime ? 'SpotCrime' : (cityDirData.policeName || 'Department Website');

        if (crimeData && crimeData.granular_crime_link) {
            crimeLink = crimeData.granular_crime_link;
            isSpotCrime = crimeLink.toLowerCase().includes('spotcrime');
            crimeSource = isSpotCrime ? 'SpotCrime' : (crimeData.police_agency || 'Department Website');
        }

        if (!crimeLink) {
            crimeLink = `https://spotcrime.com/wa/${encodeURIComponent(targetCity.toLowerCase())}`;
        }

        if (crimeData) {
            document.getElementById('safetyAgencyHeader').textContent = crimeData.police_agency || cityDirData.policeName || 'Local Law Enforcement';
            
            if (crimeData.status === "No Historical Data Reported" || crimeData.per_capita_violent_rate === null) {
                statsContainer.style.display = 'none';
                noticeBadge.classList.add('active');
            } else {
                noticeBadge.classList.remove('active');
                statsContainer.style.display = 'block';
                
                document.getElementById('txtViolentRate').textContent = typeof crimeData.per_capita_violent_rate === 'number' ? crimeData.per_capita_violent_rate.toFixed(2) : '--';
                document.getElementById('txtPropertyRate').textContent = typeof crimeData.per_capita_property_rate === 'number' ? crimeData.per_capita_property_rate.toFixed(1) : '--';
            }
        } else {
            document.getElementById('safetyAgencyHeader').textContent = cityDirData.policeName || 'Local Public Safety Status';
            statsContainer.style.display = 'none';
            noticeBadge.classList.add('active');
        }

        ctaBtn.href = crimeLink;
        ctaBtn.innerHTML = `View additional local crime data on ${crimeSource} &rarr;`;

        const fireBadgeEl = document.getElementById('fireBadgeContainer');
        const hospitalContainer = document.getElementById('hospitalProximityContainer');

        if (safetyData) {
            const f = safetyData.fire_service || {};
            document.getElementById('txtFireAgency').textContent = f.agency_name || 'Regional Fire Authority';
            
            if (f.wsrb_protection_class === null || f.wsrb_protection_class === undefined) {
                fireBadgeEl.innerHTML = `<span class="info-badge-inline badge-neutral">ℹ️ WSRB Fire Rating Evaluation Under Review.</span>`;
            } else {
                const insImpact = f.homeowners_insurance_impact || '';
                let tipMarkup = '';
                if (insImpact === "Highly Favorable" || f.wsrb_protection_class <= 3) {
                    tipMarkup = `<br><span class="label-sub" style="color:green; font-weight:700;">💰 Smart Buyer Tip: This city maintains an exceptional fire protection rating. This directly reduces your baseline annual homeowner's insurance premiums.</span>`;
                }
                fireBadgeEl.innerHTML = `
                    <span class="info-badge-inline badge-green">WSRB Protection Class: ${f.wsrb_protection_class}</span>
                    <span class="info-badge-inline badge-neutral">${insImpact}</span>
                    ${tipMarkup}
                `;
            }

            const m = safetyData.emergency_medical || {};
            if (m.nearest_hospital_facility) {
                const dist = typeof m.distance_proximity_miles === 'number' ? m.distance_proximity_miles.toFixed(1) : '--';
                hospitalContainer.innerHTML = `
                    <div style="margin-top:0.5rem; line-height:1.4;">
                        Your nearest 24/7 Emergency Department is <strong>${m.nearest_hospital_facility}</strong>, located <strong>${dist}</strong> miles away.
                        <div style="font-size:0.85rem; font-weight:700; color:var(--premier-charcoal); opacity:0.8; margin-top:0.25rem;">CMS Quality Standard: ${m.cms_hospital_quality_rating || '--'}</div>
                    </div>
                `;
            } else {
                hospitalContainer.textContent = 'Proximity logging matrix mapping pending.';
            }
        } else {
            document.getElementById('txtFireAgency').textContent = 'Responder Profile Sync Pending';
            fireBadgeEl.innerHTML = `<span class="info-badge-inline badge-neutral">ℹ️ WSRB Fire Rating Evaluation Under Review.</span>`;
            hospitalContainer.textContent = 'Local proximity calculations pending.';
        }
    };

    const renderSurveillanceMetrics = () => {
        const targetCity = currentCity.trim();
        let survData = null;

        if (dataStore.surveillance) {
            const matchedKey = Object.keys(dataStore.surveillance).find(key => key.toLowerCase() === targetCity.toLowerCase());
            if (matchedKey) survData = dataStore.surveillance[matchedKey];
        }

        const noticeBlock = document.getElementById('surveillanceNoticeBlock');
        const inventoryDataContainer = document.getElementById('surveillanceActiveData');
        const badgeEl = document.getElementById('surveillanceScoreBadge');

        if (survData) {
            document.getElementById('surveillanceAgencyLabel').textContent = survData.serving_agency || 'Municipal Security Grid';
            
            if (survData.status && (String(survData.status).includes("Insufficient Data") || survData.surveillance_score === null)) {
                badgeEl.textContent = '--';
                badgeEl.style.background = '#a0a0a0';
                inventoryDataContainer.style.display = 'none';
                noticeBlock.classList.add('active');
            } else {
                noticeBlock.classList.remove('active');
                inventoryDataContainer.style.display = 'block';
                
                const scoreVal = survData.surveillance_score;
                badgeEl.textContent = scoreVal !== null && scoreVal !== undefined ? scoreVal : '--';
                
                if (scoreVal !== null && scoreVal !== undefined) {
                    if (scoreVal >= 70) badgeEl.style.background = 'var(--card-accent-color)';
                    else if (scoreVal >= 40) badgeEl.style.background = '#1F4E5B';
                    else badgeEl.style.background = '#4A90E2';
                }

                const inv = survData.infrastructure_inventories || {};
                document.getElementById('txtAlprCount').textContent = inv.detected_alpr_cameras !== undefined && inv.detected_alpr_cameras !== null ? inv.detected_alpr_cameras : 0;
                document.getElementById('txtTrafficCount').textContent = inv.detected_traffic_cameras !== undefined && inv.detected_traffic_cameras !== null ? inv.detected_traffic_cameras : 0;
                document.getElementById('txtCctvCount').textContent = inv.detected_general_cctv !== undefined && inv.detected_general_cctv !== null ? inv.detected_general_cctv : 0;
                document.getElementById('txtSoftwareCount').textContent = inv.active_institutional_software_capabilities !== undefined && inv.active_institutional_software_capabilities !== null ? inv.active_institutional_software_capabilities : 0;
            }
        } else {
            badgeEl.textContent = '--';
            badgeEl.style.background = '#a0a0a0';
            document.getElementById('surveillanceAgencyLabel').textContent = 'Audit Matrix Offline';
            inventoryDataContainer.style.display = 'none';
            noticeBlock.classList.add('active');
        }
    };
});
</script>