<script>
    // SSG Pre-Compiled City Database Map
    const cityDatabaseMap = {
        {% for city in cityData %}
            "{{ city.City | lower }}": {
                county: "{{ city.County | lower }}",
                garbageLink: "{{ city.Garbage_Link or city.GarbageLink or '#' }}"
            },
        {% endfor %}
    };

    let debounceTimer;
    let selectedCoordinates = null;

    function handleAutocompleteDebounce() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(executeAutocomplete, 350);
    }

    async function executeAutocomplete() {
        const query = document.getElementById("address-search-input").value.trim();
        const dropdown = document.getElementById("autocomplete-suggestions");

        if (query.length < 5) {
            dropdown.classList.add("hidden");
            return;
        }

        // Limit Geocoding results strictly to Washington State locations
        const endpoint = `https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&countrycodes=us&viewbox=-124.79,49.0,-121.0,45.5&bounded=1&q=${encodeURIComponent(query)}`;

        try {
            const res = await fetch(endpoint, {
                headers: { 'User-Agent': 'MySeattleSearch-UtilityFinder/1.0' }
            });
            const data = await res.json();

            dropdown.innerHTML = "";

            if (data.length === 0) {
                dropdown.classList.add("hidden");
                return;
            }

            data.forEach(item => {
                const addr = item.address;
                
                // Formulate only the clean, desired address outputs (Bypassing neighborhood strings)
                const streetNumber = addr.house_number || "";
                const streetName = addr.road || "";
                const rawCity = addr.city || addr.town || addr.village || addr.municipality || "";
                const rawState = "WA"; // Lock to Washington footprint
                const rawZip = addr.postcode || "";

                if (!streetName || !rawCity) return; // Discard loose, generalized queries

                const cleanStreet = streetNumber ? `${streetNumber} ${streetName}` : streetName;
                const formattedAddressString = `${cleanStreet}, ${rawCity}, ${rawState} ${rawZip}`.replace(/,\s*,/g, ',');

                const suggestionNode = document.createElement("div");
                suggestionNode.className = "suggestion-item";
                suggestionNode.textContent = formattedAddressString;
                
                suggestionNode.onclick = function() {
                    document.getElementById("address-search-input").value = formattedAddressString;
                    dropdown.classList.add("hidden");
                    
                    selectedCoordinates = {
                        lat: parseFloat(item.lat),
                        lng: parseFloat(item.lon),
                        city: rawCity.toLowerCase(),
                        zip: rawZip,
                        county: (addr.county || "").toLowerCase()
                    };
                    
                    resolveLocalUtilities();
                };
                
                dropdown.appendChild(suggestionNode);
            });

            dropdown.classList.remove("hidden");

        } catch (err) {
            console.error("⚠️ Autocomplete geocoding service failed:", err);
        }
    }

    function triggerManualSearch() {
        const queryInput = document.getElementById("address-search-input").value.trim();
        if (queryInput === "") return;
        
        // If user submits without selecting autocomplete, run basic string parse match
        const parts = queryInput.split(",");
        const parsedCity = parts[1] ? parts[1].trim().toLowerCase() : "";
        
        selectedCoordinates = {
            lat: 47.6062, // Center Seattle Fallback coordinates
            lng: -122.3321,
            city: parsedCity,
            zip: parts[2] ? parts[2].replace(/\D/g, "") : "",
            county: parsedCity === "seattle" ? "king county" : ""
        };
        
        resolveLocalUtilities();
    }

    function resolveLocalUtilities() {
        if (!selectedCoordinates) return;

        const resultsBoard = document.getElementById("utility-results-board");
        const initialPrompt = document.getElementById("initial-prompt-state");
        
        const targetCity = selectedCoordinates.city;
        const targetCounty = selectedCoordinates.county;

        // Reset elements
        document.getElementById("capacity-charge-alert").classList.add("hidden");
        document.getElementById("septic-records-link").classList.add("hidden");
        document.getElementById("sewer-map-link").classList.remove("hidden");

        // 1. Resolve Power & Light
        const electricName = document.getElementById("electric-name");
        const electricLink = document.getElementById("electric-setup-link");
        const gasName = document.getElementById("gas-name");
        const gasLink = document.getElementById("gas-setup-link");

        if (targetCounty.includes("snohomish")) {
            electricName.textContent = "Snohomish County PUD";
            electricLink.href = "https://www.snopud.com/";
            gasName.textContent = "Puget Sound Energy (PSE)";
            gasLink.href = "https://www.pse.com/";
        } else if (targetCounty.includes("king") || ["seattle", "shoreline", "burien", "tukwila"].includes(targetCity)) {
            electricName.textContent = "Seattle City Light";
            electricLink.href = "https://www.seattle.gov/city-light";
            gasName.textContent = "Puget Sound Energy (PSE)";
            gasLink.href = "https://www.pse.com/";
        } else {
            // General King County default
            electricName.textContent = "Puget Sound Energy (PSE)";
            electricLink.href = "https://www.pse.com/";
            gasName.textContent = "Puget Sound Energy (PSE)";
            gasLink.href = "https://www.pse.com/";
        }

        // 2. Resolve Water & Sewer
        const waterName = document.getElementById("water-name");
        const waterQuality = document.getElementById("water-quality-link");
        const sewerType = document.getElementById("sewer-system-type");
        const sewerMap = document.getElementById("sewer-map-link");

        if (targetCity === "seattle") {
            waterName.textContent = "Seattle Public Utilities (SPU)";
            waterQuality.href = "https://www.seattle.gov/utilities/your-services/water/water-quality";
            sewerType.textContent = "SPU Sewer Utility";
            sewerMap.href = "https://www.seattle.gov/utilities/construction-resources/side-sewer-cards";
        } else if (targetCity === "edmonds" || targetCity === "woodway") {
            waterName.textContent = "Olympic View Water & Sewer District / Edmonds Water";
            waterQuality.href = "https://www.olympicviewwater.com/";
            sewerType.textContent = "Municipal Sewer Connection";
            sewerMap.href = "https://www.edmondswa.gov/services/utilities/sewer_utility";
            document.getElementById("capacity-charge-alert").classList.remove("hidden");
        } else if (targetCity === "lynnwood") {
            waterName.textContent = "Alderwood Water & Wastewater District";
            waterQuality.href = "https://awwd.com/my-water/water-quality-annual-report/";
            sewerType.textContent = "AWWD Sewer Connection";
            sewerMap.href = "https://awwd.com/developer-resources/maps-record-drawings/";
        } else {
            waterName.textContent = "Regional Municipal Utility";
            waterQuality.href = "https://www.doh.wa.gov/CommunityandEnvironment/DrinkingWater";
            sewerType.textContent = "Standard Sewer District Hookup";
            sewerMap.href = "https://kingcounty.gov/en/dept/dnrp/waste-services/wastewater-treatment";
        }

        // Trigger Septic lookup logic helper for rural pockets
        const ruralZips = ["98070", "98024", "98014", "98251", "98288"];
        if (ruralZips.includes(selectedCoordinates.zip)) {
            sewerType.textContent = "Private On-Site Septic System";
            sewerMap.classList.add("hidden");
            const septicLink = document.getElementById("septic-records-link");
            septicLink.classList.remove("hidden");
            
            if (targetCounty.includes("king")) {
                septicLink.href = "https://kingcounty.gov/en/dept/dph/health-safety/environmental-health/on-site-sewage-systems";
            } else {
                septicLink.href = "https://www.snohomishcountywa.gov/342/Septic-Systems";
            }
        }

        // Auto-show Sewer Capacity alert for all King County utility systems
        if (targetCounty.includes("king") && !ruralZips.includes(selectedCoordinates.zip)) {
            document.getElementById("capacity-charge-alert").classList.remove("hidden");
        }

        // 3. Resolve Garbage & Recycle
        const garbageName = document.getElementById("garbage-name");
        const garbageLink = document.getElementById("garbage-setup-link");

        const cityProfile = cityDatabaseMap[targetCity];
        if (cityProfile && cityProfile.garbageLink && cityProfile.garbageLink !== "#") {
            garbageName.textContent = "City-Contracted Carrier Portal";
            garbageLink.href = cityProfile.garbageLink;
        } else {
            garbageName.textContent = "County Waste Management Portal";
            garbageLink.href = targetCounty.includes("snohomish") 
                ? "https://www.snohomishcountywa.gov/200/Solid-Waste" 
                : "https://kingcounty.gov/en/dept/dnrp/waste-services/garbage-recycling-solid-waste";
        }

        // 4. Resolve Live FCC Broadband
        fetchLiveBroadbandData(selectedCoordinates.lat, selectedCoordinates.lng);

        initialPrompt.classList.add("hidden");
        resultsBoard.classList.remove("results-hidden");
    }

    async function fetchLiveBroadbandData(lat, lng) {
        const listContainer = document.getElementById("broadband-providers-list");
        const loader = document.getElementById("internet-loading-state");
        
        listContainer.innerHTML = "";
        loader.classList.remove("hidden");

        // Real-time API query targeting broadbandmap.com's endpoint
        // Utilizes a fallback to clean provider direct checkers if demo quota is exhausted or un-keyed
        const apiEndpoint = `https://broadbandmap.com/api/v1/location/internet?lat=${lat}&lng=${lng}`;

        try {
            const res = await fetch(apiEndpoint, {
                headers: {
                    // Enter your BroadbandMap.com API key here if utilizing paid/keyed plans
                    // 'Authorization': 'Bearer YOUR_KEY_GOES_HERE'
                }
            });

            if (res.status === 200) {
                const data = await res.json();
                loader.classList.add("hidden");

                if (data.providers && data.providers.length > 0) {
                    data.providers.forEach(p => {
                        const row = document.createElement("tr");
                        
                        let checkUrl = "https://www.broadbandmap.fcc.gov/";
                        if (p.name.toLowerCase().includes("comcast") || p.name.toLowerCase().includes("xfinity")) {
                            checkUrl = "https://www.xfinity.com/overview";
                        } else if (p.name.toLowerCase().includes("ziply")) {
                            checkUrl = "https://ziplyfiber.com/";
                        } else if (p.name.toLowerCase().includes("century") || p.name.toLowerCase().includes("quantum")) {
                            checkUrl = "https://www.quantumfiber.com/";
                        }

                        row.innerHTML = `
                            <td><strong>${p.name}</strong></td>
                            <td>${p.technology || 'Fixed Line'}</td>
                            <td>${p.max_download_mbps ? p.max_download_mbps + ' Mbps' : 'Speeds Vary'}</td>
                            <td><a href="${checkUrl}" target="_blank" rel="noopener" class="provider-action-btn">Check Availability &rarr;</a></td>
                        `;
                        listContainer.appendChild(row);
                    });
                    return;
                }
            }
            throw new Error("API Quota Empty or Key Unassigned");

        } catch (err) {
            // Secure Fallback: Renders clean, ad-free local direct links
            loader.classList.add("hidden");
            
            const localCarriers = [
                { name: "Ziply Fiber", tech: "Fiber Optic (Giga-Speed)", speed: "Up to 5000 Mbps", link: "https://ziplyfiber.com/" },
                { name: "Comcast Xfinity", tech: "Coaxial Cable", speed: "Up to 1200 Mbps", link: "https://www.xfinity.com/" },
                { name: "CenturyLink / Quantum", tech: "DSL / Fiber", speed: "Up to 940 Mbps", link: "https://www.quantumfiber.com/" }
            ];

            localCarriers.forEach(c => {
                const row = document.createElement("tr");
                row.innerHTML = `
                    <td><strong>${c.name}</strong></td>
                    <td>${c.tech}</td>
                    <td>${c.speed}</td>
                    <td><a href="${c.link}" target="_blank" rel="noopener" class="provider-action-btn">Address Checker &rarr;</a></td>
                `;
                listContainer.appendChild(row);
            });
        }
    }
</script>