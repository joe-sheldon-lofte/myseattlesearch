---
layout: base.njk
pagination:
  data: team.eligiblePages
  size: 1
  alias: member
  addAllPages: true
permalink: "/team/{{ member.slug }}/"
eleventyComputed:
  title: "{{ member.name }} | {{ member.position }}"
---
<!-- Google Structured Data Event Schema for SEO Dominance -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "{{ member.name }}",
  "jobTitle": "{{ member.position }}",
  "worksFor": {
    "@type": "Organization",
    "name": "Joe Sheldon Real Estate"
  },
  "description": "{{ member.description | replace('\"', '\\\"') }}"
}
</script>

<div class="member-detail-container" style="width: 100%; max-width: 1140px; margin: 0 auto; padding: 2rem 1rem;">
    
    <nav class="no-print-section" style="margin-bottom: 2rem;">
        <a href="/team/" style="color: var(--premier-charcoal); text-decoration: underline; font-weight: 700; font-size: 0.9rem;">&larr; Back to Team Directory</a>
    </nav>

    <div class="member-editorial-layout" style="display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: flex-start;">
        
        <!-- LEFT BIO CANVAS SIDEBAR FRAME (1/3 Width on Widescreen) -->
        <aside style="display: flex; flex-direction: column; gap: 1.5rem; background-color: var(--white); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.06); text-align: center;">
            {% if member.photo %}
                <img src="{{ member.photo }}" alt="{{ member.name }}" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 6px; border: 1px solid rgba(0,0,0,0.05);">
            {% else %}
                <div style="width: 100%; height: 250px; border-radius: 6px; background-color: var(--dynamic-bg-highlight); display: flex; align-items: center; justify-content: center; font-size: 3rem; color: var(--card-accent-color); font-weight: 800;">{{ member.name[0] }}</div>
            {% endif %}
            
            <div style="text-align: center;">
                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px; display: block; margin-bottom: 0.25rem;">{{ member.position }}</span>
                <h1 style="font-size: 1.75rem; font-weight: 800; color: var(--premier-charcoal); margin: 0; letter-spacing: -0.5px;">{{ member.name }}</h1>
            </div>

            <div style="border-top: 1px solid rgba(0,0,0,0.06); padding-top: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.92rem; font-weight: 600; text-align: left;">
                {% if member.phone %}
                    <a href="tel:{{ member.phone | replace('-', '') }}" style="color: var(--premier-charcoal); text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">📞 {{ member.phone }}</a>
                {% endif %}
                {% if member.email %}
                    <a href="mailto:{{ member.email }}" style="color: var(--card-accent-color); text-decoration: none; display: flex; align-items: center; gap: 0.5rem; word-break: break-all;">✉️ {{ member.email }}</a>
                {% endif %}
                {% if member.website %}
                    <a href="{{ member.website }}" target="_blank" style="color: var(--premier-charcoal); text-decoration: underline; display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem;">🌐 View Website &rarr;</a>
                {% endif %}
            </div>
        </aside>

        <!-- RIGHT CANVAS MAIN CONTENT (2/3 Width on Widescreen) -->
        <main style="background-color: var(--white); border-radius: 8px; padding: 2rem; border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 15px rgba(0,0,0,0.02);">
            <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--premier-charcoal); margin-top: 0; margin-bottom: 1rem; border-bottom: 2px solid var(--premier-beige); padding-bottom: 0.5rem;">Professional Profile</h2>
            
            {% if member.description %}
                <p style="font-size: 1rem; line-height: 1.7; color: var(--premier-charcoal); white-space: pre-line; text-align: justify; margin: 0;">{{ member.description }}</p>
            {% else %}
                <p style="font-size: 1rem; line-height: 1.7; color: var(--premier-charcoal); font-style: italic; margin: 0;">Professional biography details are currently being updated.</p>
            {% endif %}
        </main>

    </div>
</div>

<style>
    @media (min-width: 768px) {
        .member-editorial-layout {
            grid-template-columns: 1fr 2fr !important;
        }
    }
</style>