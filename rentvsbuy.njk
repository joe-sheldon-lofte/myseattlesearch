<script>
    let parsedFeedRatesRegistry = {
        'Conventional': 6.50,
        'FHA': 6.125,
        'VA': 6.125
    };
    let activeLockStateAutomated = true;

    document.addEventListener('DOMContentLoaded', () => {
        fetchLiveDailyMarketRates();
    });

    async function fetchLiveDailyMarketRates() {
        try {
            const res = await fetch('/data/hourly_rates.json');
            if (!res.ok) throw new Error("Rates JSON not found");
            const rows = await res.json();
            
            if (rows && rows.length > 0) {
                const validRows = rows.filter(r => Object.values(r)[0] && String(Object.values(r)[0]).trim() !== '');
                validRows.sort((a, b) => new Date(Object.values(a)[0].split(' ')[0]) - new Date(Object.values(b)[0].split(' ')[0]));
                
                const latestRow = validRows[validRows.length - 1];
                const latestVals = Object.values(latestRow);
                
                const convRate = parseFloat(latestVals[1]);
                const fhaRate = parseFloat(latestVals[2]);
                const vaRate = parseFloat(latestVals[3]);

                if (!isNaN(convRate)) parsedFeedRatesRegistry['Conventional'] = convRate;
                if (!isNaN(fhaRate)) parsedFeedRatesRegistry['FHA'] = fhaRate;
                if (!isNaN(vaRate)) parsedFeedRatesRegistry['VA'] = vaRate;
            }
            evaluateLiveRateLockAdjustments();
        } catch (e) {
            console.error("Error fetching live rates feed, utilizing baseline fallbacks:", e);
            evaluateLiveRateLockAdjustments();
        }
    }

    function handleLoanTypeMenuShift() {
        activeLockStateAutomated = true;
        evaluateLiveRateLockAdjustments();
    }

    function handleDownPaymentManualOverride() {
        activeLockStateAutomated = false;
        evaluateLiveRateLockAdjustments();
    }

    function evaluateLiveRateLockAdjustments() {
        const type = document.getElementById('inLoanType').value;
        const credit = parseInt(document.getElementById('inCreditScore').value) || 740;
        const price = parseFloat(document.getElementById('inPrice').value) || 0;
        const downValEl = document.getElementById('inDownValue');
        const unitEl = document.getElementById('inDownUnit');
        const rateInput = document.getElementById('inRate');

        if (activeLockStateAutomated && price > 0) {
            if (type === 'VA') { downValEl.value = 0; unitEl.value = '%'; } 
            else if (type === 'FHA') { downValEl.value = 3.5; unitEl.value = '%'; } 
            else { downValEl.value = 5; unitEl.value = '%'; }
        }

        let baseRate = parsedFeedRatesRegistry[type] || 6.50;
        let adjustmentFactor = 0;

        if (type === 'Conventional' && price > 0) {
            const manualDownValue = parseFloat(downValEl.value) || 0;
            let computedDownPct = manualDownValue;
            if (unitEl.value === '$') computedDownPct = (manualDownValue / price) * 100;

            if (credit < 660) adjustmentFactor += 1.00;
            else if (credit < 700) adjustmentFactor += 0.625;
            else if (credit < 740) adjustmentFactor += 0.25;

            if (computedDownPct < 5) adjustmentFactor += 0.25;
            if (computedDownPct >= 20) adjustmentFactor -= 0.25; 
        }

        rateInput.value = (baseRate + adjustmentFactor).toFixed(3);
    }

    function handleSliderMovementValueUpdate(val) {
        const lbl = document.getElementById('lblCycleVal');
        if (parseFloat(val) > 30) lbl.textContent = "Full 30-Year Timeline (No Resets)";
        else lbl.textContent = parseFloat(val).toFixed(1) + " Years";
    }

    function handleSliderMovementValueUpdate(val) {
        const lbl = document.getElementById('lblCycleVal');
        if (parseFloat(val) > 30) lbl.textContent = "Full 30-Year Timeline (No Resets)";
        else lbl.textContent = parseFloat(val).toFixed(1) + " Years";
    }

    function handleViewModeConfigurationChange(val) {
        const sliderInput = document.getElementById('inCycleLength');
        if (val === 'flat30') { sliderInput.value = 31; handleSliderMovementValueUpdate(31); } 
        else { sliderInput.value = 10.3; handleSliderMovementValueUpdate(10.3); }
    }

    function calculateAmortizationMonthlyPayment(principal, annualRate) {
        if (principal <= 0) return 0;
        const monthlyRate = (annualRate / 100) / 12;
        const totalPaymentsCount = 360;
        if (monthlyRate === 0) return principal / totalPaymentsCount;
        return principal * (monthlyRate * Math.pow(1 + monthlyRate, totalPaymentsCount)) / (Math.pow(1 + monthlyRate, totalPaymentsCount) - 1);
    }

    function estimateFederalTaxBracketMarginalRate(income) {
        if (income > 250000) return 0.32;
        if (income > 100000) return 0.24;
        if (income > 45000) return 0.22;
        return 0.12;
    }

    function formatCurrency(num) {
        return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(num);
    }

    function generateComparativeWealthTimeline() {
        const startAge = parseInt(document.getElementById('inAge').value) || 30;
        const income = parseFloat(document.getElementById('inIncome').value) || 0;
        let baseRent = parseFloat(document.getElementById('inRent').value) || 0;
        let basePrice = parseFloat(document.getElementById('inPrice').value) || 0;
        const inputRateVal = parseFloat(document.getElementById('inRate').value) || 6.5;
        const programType = document.getElementById('inLoanType').value;
        const viewMode = document.getElementById('inViewMode').value;
        
        let targetCycleLength = parseFloat(document.getElementById('inCycleLength').value) || 10.3;
        let executeCyclicResets = true;
        if (targetCycleLength > 30 || viewMode === 'flat30') { executeCyclicResets = false; targetCycleLength = 999; }

        const downValueFieldInput = parseFloat(document.getElementById('inDownValue').value) || 0;
        const downUnitSelectField = document.getElementById('inDownUnit').value;
        const appreciation = 4.5;
        const rentInflation = 4.0;
        const moveFreq = 3;
        const moveCost = 2500;
        const standardDeductionLimit = 15600;
        const federalMarginalTaxBracket = estimateFederalTaxBracketMarginalRate(income);

        let calculatedDownPaymentDollars = downValueFieldInput;
        if (downUnitSelectField === '%') calculatedDownPaymentDollars = basePrice * (downValueFieldInput / 100);

        let principalFirstMortgage = basePrice - calculatedDownPaymentDollars;
        let initialUpfrontPremiumWrapped = 0;

        if (programType === 'FHA') {
            initialUpfrontPremiumWrapped = principalFirstMortgage * 0.0175;
            principalFirstMortgage += initialUpfrontPremiumWrapped;
        } else if (programType === 'VA') {
            initialUpfrontPremiumWrapped = principalFirstMortgage * 0.0215;
            principalFirstMortgage += initialUpfrontPremiumWrapped;
            calculatedDownPaymentDollars = 0; 
        }

        let activeMonthlyPI = calculateAmortizationMonthlyPayment(principalFirstMortgage, inputRateVal);
        let cumulativeBuyerOutflow = calculatedDownPaymentDollars;
        let cumulativeRenterOutflow = 0;
        let cycleTimerCounter = 0;
        let lastRenderedPhaseLabel = '';
        const maxTimelineYearsHorizon = (viewMode === 'flat30') ? 30 : Math.max(30, 85 - startAge);
        const tableBodyOutput = document.getElementById('timelineTableBodyOutput');
        let htmlBuffer = '';
        let currentHomeValue = basePrice;
        let activeLoanBalance = principalFirstMortgage;

        for (let year = 1; year <= maxTimelineYearsHorizon; year++) {
            const currentAgeIndex = startAge + year - 1;
            cycleTimerCounter++;

            if (viewMode !== 'flat30') {
                let currentPhaseLabel = '';
                if (currentAgeIndex < 40) currentPhaseLabel = "Career & Family Building Years (Ages 18-39)";
                else if (currentAgeIndex < 55) currentPhaseLabel = "Peak Earning Years (Ages 40-54)";
                else if (currentAgeIndex < 67) currentPhaseLabel = "Pre-Retirement & Wealth Consolidation (Ages 55-66)";
                else currentPhaseLabel = "Retirement Horizon (Ages 67+)";

                if (currentPhaseLabel !== lastRenderedPhaseLabel) {
                    htmlBuffer += `<tr class="phase-header-row"><td colspan="7">${currentPhaseLabel}</td></tr>`;
                    lastRenderedPhaseLabel = currentPhaseLabel;
                }
            }

            let annualInterestPaidThisYear = 0;
            let annualPmiPaidThisYear = 0;

            if (year <= 30) {
                for (let month = 1; month <= 12; month++) {
                    if (activeLoanBalance > 0) {
                        const monthlyInterestAccrual = activeLoanBalance * ((inputRateVal / 100) / 12);
                        const monthlyPrincipalAccrual = activeMonthlyPI - monthlyInterestAccrual;
                        annualInterestPaidThisYear += monthlyInterestAccrual;
                        activeLoanBalance -= monthlyPrincipalAccrual;
                        let currentLtvDownPct = downValueFieldInput;
                        if (downUnitSelectField === '$') currentLtvDownPct = (downValueFieldInput / basePrice) * 100;
                        if (programType === 'Conventional' && activeLoanBalance > (basePrice * 0.80) && currentLtvDownPct < 20) {
                            annualPmiPaidThisYear += ((basePrice - calculatedDownPaymentDollars) * 0.005) / 12;
                        } else if (programType === 'FHA') {
                            annualPmiPaidThisYear += (principalFirstMortgage * 0.0055) / 12;
                        }
                    }
                }
            }

            if (activeLoanBalance < 0 || year > 30) activeLoanBalance = 0;

            const computedPropertyTaxThisYear = currentHomeValue * 0.009;
            let insuranceSlopeValue = 1200;
            if (currentHomeValue > 500000) insuranceSlopeValue += (currentHomeValue - 500000) * (1800 / 1000000);
            const maintenanceReservesCostThisYear = currentHomeValue * 0.01;

            const itemizedDeductionSumTotal = annualInterestPaidThisYear + computedPropertyTaxThisYear;
            let annualTaxSavingsBenefitValue = 0;
            if (itemizedDeductionSumTotal > standardDeductionLimit) {
                annualTaxSavingsBenefitValue = (itemizedDeductionSumTotal - standardDeductionLimit) * federalMarginalTaxBracket;
            }

            const actualMortgageCashFlowThisYear = (year <= 30 && activeLoanBalance > 0) ? (activeMonthlyPI * 12) : 0;
            const grossBuyingCostsThisYear = actualMortgageCashFlowThisYear + annualPmiPaidThisYear + computedPropertyTaxThisYear + insuranceSlopeValue + maintenanceReservesCostThisYear;
            cumulativeBuyerOutflow += (grossBuyingCostsThisYear - annualTaxSavingsBenefitValue);

            let renterFrictionCostsThisYear = (baseRent * 12);
            let flagMovingFrictionTrigger = false;
            if (year % moveFreq === 0) {
                renterFrictionCostsThisYear += moveCost;
                flagMovingFrictionTrigger = true;
            }
            cumulativeRenterOutflow += renterFrictionCostsThisYear;

            currentHomeValue = currentHomeValue * (1 + (appreciation / 100));
            let accumulatedCurrentHomeEquity = currentHomeValue - activeLoanBalance;

            let milestoneMarkupClass = '';
            let narrativeNoteBlockText = `Includes an allocation of ${formatCurrency(maintenanceReservesCostThisYear)} for property maintenance and asset care variables.`;
            if (annualTaxSavingsBenefitValue > 0) narrativeNoteBlockText += ` Estimated federal tax deductions reduce annual tax liability by ${formatCurrency(annualTaxSavingsBenefitValue)} for this year.`;
            let downPctCheck = downValueFieldInput;
            if (downUnitSelectField === '$') downPctCheck = (downValueFieldInput / basePrice) * 100;
            if (programType === 'Conventional' && annualPmiPaidThisYear === 0 && downPctCheck < 20 && activeLoanBalance > 0 && year <= 30) narrativeNoteBlockText += ` Private mortgage insurance (PMI) requirements are removed as the remaining balance falls beneath the eighty percent loan-to-value threshold.`;
            if (year > 30) narrativeNoteBlockText = `The mortgage loan is fully paid off. Remaining property expenses consist of local taxes, insurance, and routine home care upkeep.`;

            if (executeCyclicResets && cycleTimerCounter >= Math.floor(targetCycleLength) && year < 30) {
                milestoneMarkupClass = 'cycle-transition-row';
                const salesTransactionFrictionCosts = currentHomeValue * 0.07;
                const liquidatedNetProceedsEquityCash = currentHomeValue - activeLoanBalance - salesTransactionFrictionCosts;
                basePrice = currentHomeValue; 
                currentHomeValue = basePrice;
                calculatedDownPaymentDollars = liquidatedNetProceedsEquityCash;
                activeLoanBalance = basePrice - calculatedDownPaymentDollars;
                if (programType === 'FHA') activeLoanBalance += (activeLoanBalance * 0.0175);
                else if (programType === 'VA') activeLoanBalance += (activeLoanBalance * 0.0215);
                activeMonthlyPI = calculateAmortizationMonthlyPayment(activeLoanBalance, inputRateVal);
                cumulativeBuyerOutflow += salesTransactionFrictionCosts; 
                accumulatedCurrentHomeEquity = currentHomeValue - activeLoanBalance;
                narrativeNoteBlockText = `<span class="milestone-tag-badge badge-cycle">Property Sale</span> Based on average Washington state patterns, this year reflects selling the home, accounting for typical transaction closing fees, and rolling the net cash proceeds into a subsequent property purchase.`;
                cycleTimerCounter = 0;
            }

            if (flagMovingFrictionTrigger && milestoneMarkupClass === '') narrativeNoteBlockText += ` Moving year: Includes an estimated ${formatCurrency(moveCost)} in relocation expenses.`;

            if (!executeCyclicResets) {
                if (year === 10) { milestoneMarkupClass = 'flat-milestone-row'; narrativeNoteBlockText = `<span class="milestone-tag-badge badge-flat">Tenure Baseline</span> This year matches the general ownership timeline duration tracked across local municipality properties.`; } 
                else if (year === 15) { milestoneMarkupClass = 'flat-milestone-row'; narrativeNoteBlockText = `<span class="milestone-tag-badge">Amortization Crossover</span> At this point in the standard thirty year timeline, the monthly principal reduction exceeds the monthly interest portion of the payment.`; } 
                else if (year === 30) { milestoneMarkupClass = 'flat-milestone-row'; narrativeNoteBlockText = `<span class="milestone-tag-badge badge-flat">Loan Completed</span> The primary mortgage is fully paid off. Subsequent property obligations are limited to property taxes and insurance distributions.`; }
            }

            const netWealthVarianceResult = accumulatedCurrentHomeEquity - (cumulativeBuyerOutflow - cumulativeRenterOutflow);
            const avgMonthlyBuyerCost = grossBuyingCostsThisYear / 12;
            const avgMonthlyRenterCost = renterFrictionCostsThisYear / 12;

            htmlBuffer += `
                <tr class="${milestoneMarkupClass}">
                    <td class="cell-year-header">Age ${currentAgeIndex}<br><span style="font-size:0.75rem; color:#666; font-weight:700;">(Year ${year})</span></td>
                    <td>${formatCurrency(currentHomeValue)}</td>
                    <td>${activeLoanBalance > 0 ? formatCurrency(activeLoanBalance) : 'Paid Off'}</td>
                    <td class="cell-cost-negative">${formatCurrency(avgMonthlyBuyerCost)}/mo</td>
                    <td class="cell-cost-negative">${formatCurrency(avgMonthlyRenterCost)}/mo</td>
                    <td class="cell-wealth-positive">${formatCurrency(accumulatedCurrentHomeEquity)}</td>
                    <td class="${netWealthVarianceResult > 0 ? 'cell-wealth-positive' : 'cell-cost-negative'}">${netWealthVarianceResult > 0 ? 'Buyer +' + formatCurrency(netWealthVarianceResult) : 'Renter +' + formatCurrency(Math.abs(netWealthVarianceResult))}</td>
                </tr>
                <tr class="narrative-row"><td colspan="7"><span class="timeline-narrative-text">${narrativeNoteBlockText}</span></td></tr>
            `;
            baseRent = baseRent * (1 + (rentInflation / 100));
        }

        tableBodyOutput.innerHTML = htmlBuffer;
        document.getElementById('resultsCardWrapper').style.display = 'block';
        document.getElementById('resultsCardWrapper').scrollIntoView({ behavior: 'smooth' });
    }
</script>