---
layout: base.njk
title: "Joe's Notebook"
permalink: /notebook/
pagination:
  data: collections.posts
  size: 25
  alias: items
  reverse: true
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Joe Sheldon's Social Notebook",
  "description": "A collection of posts, notes, and articles on Greater Seattle real estate written by Redfin Agent Joe Sheldon.",
  "url": "https://myseattlesearch.com/notebook/",
  "publisher": {
    "@type": "RealEstateAgent",
    "name": "Joe Sheldon - Redfin Real Estate Agent",
    "url": "https://myseattlesearch.com"
  }
}
</script>

<style>
  .notebook-master-wrapper {
    max-width: 800px;
    margin: 2.5rem auto;
    padding: 0 1rem;
    box-sizing: border-box;
    text-align: left;
  }
  .notebook-masthead {
    text-align: center;
    margin-bottom: 2.5rem;
    border-bottom: 2px solid var(--dynamic-bg-highlight);
    padding-bottom: 1.5rem;
  }
  .notebook-masthead h1 {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--premier-charcoal);
    margin: 0 0 0.35rem 0;
    letter-spacing: -0.02em;
  }
  .notebook-masthead p {
    font-size: 1.15rem;
    color: rgba(0,0,0,0.6);
    margin: 0;
    font-weight: 500;
  }
  .notebook-body p {
    margin: 0 0 1rem 0;
  }
  .notebook-body p:last-child {
    margin-bottom: 0;
  }
  .image-badge-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    margin-left: 0.5rem;
  }
  .image-badge-indicator.post-style {
    background-color: rgba(255, 255, 255, 0.25);
    color: var(--white);
  }
  .image-badge-indicator.other-style {
    background-color: var(--dynamic-bg-highlight);
    color: var(--card-accent-color);
    border: 1px solid var(--card-accent-color);
  }
</style>

<div class="notebook-master-wrapper">
  
  {# Public Platform Brand Header #}
  <header class="notebook-masthead">
    <h1>Joe's Notebook</h1>
    <p>A collection of posts, notes, and articles written by Joe.</p>
  </header>

  <div class="notebook-master-canvas" style="display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">
    {% for item in items %}
      {% if item.data.type %}
        {% set typeLower = item.data.type.toLowerCase() %}
        {% set isPost = typeLower == "post" %}
        {% set isNote = typeLower == "note" %}
        {% set isArticle = typeLower == "article" %}
        
        {# Count attached images #}
        {% set imgCount = 0 %}
        {% if item.data.image_1 %}{% set imgCount = imgCount + 1 %}{% endif %}
        {% if item.data.image_2 %}{% set imgCount = imgCount + 1 %}{% endif %}
        {% if item.data.image_3 %}{% set imgCount = imgCount + 1 %}{% endif %}
        {% if item.data.image_4 %}{% set imgCount = imgCount + 1 %}{% endif %}
        {% if item.data.image_5 %}{% set imgCount = imgCount + 1 %}{% endif %}

        {% set absoluteUrl = "https://myseattlesearch.com" + item.url %}
        {% set navLabel = "View Entry →" %}
        
        {# Polymorphic Architecture Matrix #}
        <article class="notebook-card type-{{ typeLower }}" style="border-radius: 6px; width: 100%; box-sizing: border-box; position: relative; {% if isPost %}padding: 1.25rem; background-color: var(--card-accent-color); border: none;{% elif isNote %}padding: 1.5rem; border: 3px solid var(--card-accent-color); background-color: var(--dynamic-bg-highlight);{% else %}padding: 1.75rem; border: 1px solid var(--card-accent-color); background-color: var(--white);{% endif %}">
          
          {# Upper Section Alignment Controls #}
          <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
            <div style="display: flex; align-items: center;">
              <span style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800; font-size: 0.8rem; color: {% if isPost %}var(--white){% else %}var(--card-accent-color){% endif %};">{{ item.data.type }}</span>
              {% if imgCount > 0 %}
                <span class="image-badge-indicator {% if isPost %}post-style{% else %}other-style{% endif %}">
                  📷 {{ imgCount }} {% if imgCount == 1 %}Photo{% else %}Photos{% endif %}
                </span>
              {% endif %}
            </div>
            
            {% if isPost %}{% set navLabel = "View Post →" %}{% elif isNote %}{% set navLabel = "View Note →" %}{% else %}{% set navLabel = "View Article →" %}{% endif %}
            <a href="{{ item.url }}" style="font-weight: 700; text-decoration: underline; text-underline-offset: 3px; font-size: 0.85rem; color: {% if isPost %}var(--white){% else %}var(--card-accent-color){% endif %};">{{ navLabel }}</a>
          </header>
          
          {# Data Visibility Rules #}
          {% if item.data.headline or item.data.title %}
            <h2 style="margin: 0 0 0.4rem 0; font-size: {% if isNote %}1.35rem{% else %}1.5rem{% endif %}; font-weight: 800; color: {% if isPost %}var(--white){% else %}var(--premier-charcoal){% endif %}; line-height: 1.2;">
              {{ item.data.headline if item.data.headline else item.data.title }}
            </h2>
          {% endif %}
          {% if isArticle and item.data.subhead %}
            <p style="margin: 0 0 0.75rem 0; font-size: 1rem; font-style: italic; color: rgba(0,0,0,0.6);">{{ item.data.subhead }}</p>
          {% endif %}
          
          <div class="notebook-body" style="{% if isPost %}color: var(--white); font-size: 1.15rem; font-weight: 600; line-height: 1.45;{% else %}color: var(--premier-charcoal); font-size: 1.05rem;{% endif %} margin-bottom: 0.85rem;">
            {% if isArticle %}
              {% set cleanContent = item.templateContent | striptags | trim %}
              <p style="margin: 0;">{{ cleanContent | truncate(240) }}</p>
            {% else %}
              {{ item.templateContent | safe }}
            {% endif %}
          </div>
          
          {# Low-Profile Split Base Ribbon #}
          <footer style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; background-color: {% if isPost %}rgba(255,255,255,0.15){% else %}rgba(0,0,0,0.03){% endif %}; padding: 0.4rem 0.75rem; border-radius: 4px; font-size: 0.8rem; gap: 0.5rem;">
            <div style="flex: 1 1 260px; font-weight: 500; color: {% if isPost %}var(--white){% else %}rgba(0,0,0,0.65){% endif %};">
              By: {{ item.data.author or "Joe Sheldon" }} • {{ item.data.date | postDate }}
            </div>
            <div style="flex: 1 1 auto; display: flex; justify-content: flex-end; gap: 0.5rem; align-items: center;">
              <button class="notebook-share-btn" data-url="{{ absoluteUrl }}" data-title="{{ item.data.headline or item.data.title or 'Notebook Update' }}" style="background: var(--white); border: 1px solid rgba(0,0,0,0.15); padding: 0.25rem 0.5rem; border-radius: 3px; font-weight: 600; cursor: pointer; font-size: 0.75rem; color: var(--premier-charcoal); display: inline-flex; align-items: center; gap: 0.25rem;">
                🔄 Share
              </button>
              <a href="/chat/?reply_to={{ item.fileSlug }}" style="background: var(--white); border: 1px solid rgba(0,0,0,0.15); padding: 0.25rem 0.5rem; border-radius: 3px; font-weight: 600; text-decoration: none; font-size: 0.75rem; color: var(--premier-charcoal); display: inline-flex; align-items: center; gap: 0.25rem;">
                💬 Reply
              </a>
            </div>
          </footer>
        </article>
      {% endif %}
    {% endfor %}
  </div>

  {# Stream Navigation Refinements #}
  {% if pagination.pages.length > 1 %}
    <nav class="notebook-pagination" style="display: flex; justify-content: center; align-items: center; gap: 1.5rem; margin-top: 3.5rem; font-family: sans-serif;">
      {% if pagination.href.previous %}
        <a href="{{ pagination.href.previous }}" style="color: var(--card-accent-color); font-weight: 700; text-decoration: none; border: 1px solid var(--card-accent-color); padding: 0.4rem 0.9rem; border-radius: 4px; font-size: 0.9rem;"><- Newer</a>
      {% else %}
        <span style="color: rgba(0,0,0,0.3); border: 1px solid rgba(0,0,0,0.1); padding: 0.4rem 0.9rem; border-radius: 4px; font-size: 0.9rem;"><- Newer</span>
      {% endif %}
      
      <span style="font-weight: 600; color: rgba(0,0,0,0.5); font-size: 0.85rem;">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
      
      {% if pagination.href.next %}
        <a href="{{ pagination.href.next }}" style="color: var(--card-accent-color); font-weight: 700; text-decoration: none; border: 1px solid var(--card-accent-color); padding: 0.4rem 0.9rem; border-radius: 4px; font-size: 0.9rem;">Older -></a>
      {% else %}
        <span style="color: rgba(0,0,0,0.3); border: 1px solid rgba(0,0,0,0.1); padding: 0.4rem 0.9rem; border-radius: 4px; font-size: 0.9rem;">Older -></span>
      {% endif %}
    </nav>
  {% endif %}
</div>