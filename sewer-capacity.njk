<script>
    function calculateSewerPayoff() {
        const tierSelect = document.getElementById("sewer-tier");
        const ageInput = document.getElementById("sewer-age");

        const monthlyRate = parseFloat(tierSelect.value);
        let connectedYears = parseFloat(ageInput.value);

        // Enforce basic logical boundaries on age parameters
        if (isNaN(connectedYears) || connectedYears < 0) connectedYears = 0;
        if (connectedYears > 15) connectedYears = 15;

        // Total allocation window timeline rules: 15 years = 180 months total
        const totalMonths = 180;
        const elapsedMonths = Math.floor(connectedYears * 12);
        const remainingMonths = Math.max(0, totalMonths - elapsedMonths);

        // 1. Calculate active quarterly statement obligation (3 months aggregated)
        const activeQuarterlyStatement = monthlyRate * 3;

        // 2. Calculate basic remaining Gross Liability
        const grossBalanceOwed = remainingMonths * monthlyRate;

        // 3. Model the present-value amortized payoff incentive
        // King County applies standard present-value reductions on multi-year streams.
        // We model an accurate 3.5% discount factor compounded monthly on the remaining payouts.
        let estimatedPayoffOwed = 0;
        if (remainingMonths > 0) {
            const monthlyDiscountRate = 0.035 / 12; // 3.5% per annum
            const presentValueFactor = (1 - Math.pow(1 + monthlyDiscountRate, -remainingMonths)) / monthlyDiscountRate;
            estimatedPayoffOwed = monthlyRate * presentValueFactor;
        }

        // Output formatted semantic parameters back to UI layer
        document.getElementById("sewer-quarterly-output").textContent = 
            `$${activeQuarterlyStatement.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;

        document.getElementById("sewer-gross-output").textContent = 
            `$${grossBalanceOwed.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            
        document.getElementById("sewer-discount-output").textContent = 
            `$${estimatedPayoffOwed.toLocaleString("en-US", {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
    }

    // Direct entry execution on script parsing pass
    calculateSewerPayoff();
</script>