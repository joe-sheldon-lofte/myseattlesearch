---
layout: base.njk
---

<style>
  .notebook-standalone-shell {
    max-width: 800px;
    margin: 2.5rem auto;
    padding: 0 1rem;
    box-sizing: border-box;
    text-align: left;
  }
  .standalone-card-box {
    border-radius: 6px;
    width: 100%;
    box-sizing: border-box;
    position: relative;
  }
  .standalone-card-box.type-post {
    padding: 1.25rem;
    background-color: var(--card-accent-color);
    border: none;
  }
  .standalone-card-box.type-note {
    padding: 1.5rem;
    border: 3px solid var(--card-accent-color);
    background-color: var(--dynamic-bg-highlight);
  }
  .standalone-card-box.type-article {
    padding: 1.75rem;
    border: 1px solid var(--card-accent-color);
    background-color: white;
  }
  .standalone-body p {
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }
  .standalone-body p:last-child {
    margin-bottom: 0;
  }
  .reference-links-deck {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 0.5rem 0;
  }
  .reference-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background-color: var(--card-accent-color);
    color: white;
    text-decoration: none;
    font-weight: 700;
    border-radius: 4px;
    font-size: 0.85rem;
  }
</style>

<div class="notebook-standalone-shell">
  <div style="margin-bottom: 1.25rem;">
    <a href="/notebook/" style="color: var(--card-accent-color); font-weight: 700; text-decoration: none; font-size: 0.9rem;">← Back to Notebook</a>
  </div>

  {% set typeLower = type.toLowerCase() %}
  {% set isPost = typeLower == "post" %}
  {% set isNote = typeLower == "note" %}
  {% set isArticle = typeLower == "article" %}

  <article class="standalone-card-box type-{{ typeLower }}">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
      <span style="text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800; font-size: 0.8rem; color: {% if isPost %}white{% else %}var(--card-accent-color){% endif %};">{{ type }}</span>
      <span style="font-size: 0.8rem; font-weight: 700; color: {% if isPost %}white{% else %}rgba(0,0,0,0.4){% endif %}; font-style: italic;">Viewing Entry</span>
    </header>

    {% if not isPost and headline %}
      <h1 style="margin: 0 0 0.4rem 0; font-size: {% if isNote %}1.5rem{% else %}1.85rem{% endif %}; font-weight: 900; color: var(--premier-charcoal); line-height: 1.2;">{{ headline }}</h1>
    {% endif %}
    {% if isArticle and subhead %}
      <p style="margin: 0 0 0.75rem 0; font-size: 1.05rem; font-style: italic; color: rgba(0,0,0,0.6);">{{ subhead }}</p>
    {% endif %}

    <div class="standalone-body" style="{% if isPost %}color: white; font-size: 1.15rem; font-weight: 600; line-height: 1.45;{% else %}color: var(--premier-charcoal); font-size: 1.05rem;{% endif %} margin-bottom: 1.25rem;">
      {{ content | safe }}
    </div>

    {% if url_1 or url_2 %}
      <div class="reference-links-deck">
        {% if url_1 %}
          <a href="{{ url_1 }}" target="_blank" rel="noopener noreferrer" class="reference-btn" style="{% if isPost %}background-color: white; color: var(--card-accent-color); border: 1px solid rgba(0,0,0,0.1);{% endif %}">
            🔗 {{ url_1_label if url_1_label else "Source Reference 1" }}
          </a>
        {% endif %}
        {% if url_2 %}
          <a href="{{ url_2 }}" target="_blank" rel="noopener noreferrer" class="reference-btn" style="{% if isPost %}background-color: white; color: var(--card-accent-color); border: 1px solid rgba(0,0,0,0.1);{% endif %}">
            🔗 {{ url_2_label if url_2_label else "Source Reference 2" }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    <footer style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; background-color: {% if isPost %}rgba(255,255,255,0.15){% else %}rgba(0,0,0,0.03){% endif %}; padding: 0.4rem 0.75rem; border-radius: 4px; font-size: 0.8rem; margin-top: 1.25rem; gap: 0.5rem;">
      <div style="flex: 1 1 260px; font-weight: 500; color: {% if isPost %}white{% else %}rgba(0,0,0,0.65){% endif %};">
        By: {{ author or "Joe Sheldon" }} • {{ date | postDate }}
      </div>
      <div style="flex: 1 1 auto; display: flex; justify-content: flex-end; gap: 0.5rem; align-items: center;">
        <button class="notebook-share-btn" data-url="https://myseattlesearch.com{{ page.url }}" data-title="{{ headline or 'Notebook Update' }}" style="background: white; border: 1px solid rgba(0,0,0,0.15); padding: 0.25rem 0.5rem; border-radius: 3px; font-weight: 600; cursor: pointer; font-size: 0.75rem; color: var(--premier-charcoal); display: inline-flex; align-items: center; gap: 0.25rem;">
          🔄 Share
        </button>
        <a href="/chat/?reply_to={{ page.fileSlug }}" style="background: white; border: 1px solid rgba(0,0,0,0.15); padding: 0.25rem 0.5rem; border-radius: 3px; font-weight: 600; text-decoration: none; font-size: 0.75rem; color: var(--premier-charcoal); display: inline-flex; align-items: center; gap: 0.25rem;">
          💬 Reply
        </a>
      </div>
    </footer>
  </article>
</div>