        {% set socialImage = "https://myseattlesearch.com" + socialImage %}
    {% endif %}

    <meta property="og:image" content="{{ socialImage }}">
    <meta property="og:image:alt" content="{% if title %}{{ title }}{% else %}MySeattleSearch Real Estate{% endif %}">

    <!-- Twitter / X Card Metadata -->
