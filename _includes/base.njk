    {% endif %}
    {% if not socialImage %}
        {% set socialImage = "https://assets.myseattlesearch.com/repomove/hero-living-room.webp" %}
    {% endif %}

    {# Ensure relative paths are converted to absolute URLs for social crawlers #}
