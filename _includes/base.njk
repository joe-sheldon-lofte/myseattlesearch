<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Joe Sheldon | Redfin Senior Agent | Seattle Real Estate") }}</title>
    <meta name="description" content="{{ description | default("Greater Seattle real estate insights, hyper-local market stats, and buyer & seller guides with Redfin Senior Agent Joe Sheldon.") }}">
    <meta name="build-time" content="{% buildTime %}">
    <link rel="canonical" href="https://myseattlesearch.com{{ page.url }}">

    <!-- Open Graph / Social Sharing -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://myseattlesearch.com{{ page.url }}">
    <meta property="og:title" content="{{ title | default("Joe Sheldon | Redfin Senior Agent") }}">
    <meta property="og:description" content="{{ description | default("Greater Seattle real estate insights and hyper-local market analysis.") }}">
    <meta property="og:image" content="https://assets.myseattlesearch.com/repomove/hero-living-room.webp">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title | default("Joe Sheldon | Redfin Senior Agent") }}">
    <meta name="twitter:description" content="{{ description | default("Greater Seattle real estate insights and hyper-local market analysis.") }}">
    <meta name="twitter:image" content="https://assets.myseattlesearch.com/repomove/hero-living-room.webp">

    <!-- Google Fonts: Dancing Script for Handwriting Signatures -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&display=swap" rel="stylesheet">

    <!-- Inlined Core Site Stylesheet (Zero Network Render-Blocking Delay) -->
    <style>
      {% include "../style.css" %}
    </style>

    <!-- Schema.org JSON-LD Global Real Estate Agent Entity -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Person", "RealEstateAgent"],
      "@id": "https://myseattlesearch.com/#agent",
      "name": "Joe Sheldon",
      "jobTitle": "Senior Real Estate Agent",
      "worksFor": {
        "@type": "Organization",
        "name": "Redfin",
        "url": "https://www.redfin.com"
      },
      "image": "https://assets.myseattlesearch.com/repomove/joe.webp",
      "telephone": "(206) 657-7493",
      "email": "joe.sheldon@redfin.com",
      "url": "https://myseattlesearch.com",
      "sameAs": [
        "https://www.redfin.com/real-estate-agents/joe-sheldon",
        "https://www.facebook.com/myseattlesearch",
        "https://www.instagram.com/myseattlesearch"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "3400 188th St SW, Ste 165",
        "addressLocality": "Lynnwood",
        "addressRegion": "WA",
        "postalCode": "98037",
        "addressCountry": "US"
      },
      "areaServed": [
        "Lynnwood", "Mountlake Terrace", "Lake Forest Park", "Edmonds",
        "Shoreline", "Brier", "Woodinville", "Kenmore", "Mukilteo",
        "Seattle", "Bellevue", "Snohomish County", "King County"
      ]
    }
    </script>
</head>
<body>

    <!-- Modular Navigation Header -->
    {% include "header.njk" %}

    <!-- Main Viewport Body Container -->
    <main class="{{ containerClass | default('container') }}">
        {{ content | safe }}
    </main>

    <!-- Global Footer -->
    {% include "footer.njk" %}

    <!-- Lite YouTube Embed Web Component -->
    <script type="module" src="https://cdn.jsdelivr.net/npm/@justinribeiro/lite-youtube@1.5.0/lite-youtube.js"></script>
</body>
</html>