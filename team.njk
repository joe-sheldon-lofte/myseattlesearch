---
layout: base.njk
title: "Meet the Team | Real Estate Experts"
permalink: /team/
---
<div class="team-directory-container" style="width: 100%; max-width: 1140px; margin: 0 auto;">
    
    <header class="directory-header" style="text-align: center; margin-bottom: 3.5rem; border-bottom: 2px solid rgba(0,0,0,0.05); padding-bottom: 1.5rem;">
        <h1 style="font-size: 2.5rem; font-weight: 900; color: var(--card-accent-color); letter-spacing: -0.75px; margin-bottom: 0.5rem;">Meet Joe's Team</h1>
        <p style="font-size: 1.1rem; color: var(--premier-charcoal); opacity: 0.8; max-width: 650px; margin: 0 auto;">Dedicated professionals working seamlessly together to deliver an elite experience during your real estate journey.</p>
    </header>

    <!-- CORE 4 TOP HIERARCHY GRID CANVAS (Splits Left vs Right Operations) -->
    <section class="core-four-framework-block" style="margin-bottom: 4rem;">
        <div class="core-four-grid" style="display: grid; grid-template-columns: 1fr; gap: 2.5rem;">
            
            <!-- LEFT COLUMN CANVAS: Real Estate Operations Pipeline -->
            <div style="display: flex; flex-direction: column; gap: 2.5rem;">
                <!-- 1. Senior Agent Card (Joe Sheldon) -->
                {% if team.seniorAgent and team.seniorAgent.teamPage %}
                    <article class="profile-card premium-shadow" style="background-color: var(--white); border-radius: 8px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06); display: flex; flex-direction: column; border-top: 5px solid var(--card-accent-color);">
                        {% if team.seniorAgent.photo %}
                            <img src="{{ team.seniorAgent.photo }}" alt="{{ team.seniorAgent.name }}" width="400" height="380" loading="lazy" decodes="async" style="width: 100%; max-height: 380px; object-fit: cover; display: block;">
                        {% endif %}
                        <div style="padding: 1.75rem; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; gap: 1rem;">
                            <div style="text-align: left;">
                                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px;">{{ team.seniorAgent.position }}</span>
                                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--premier-charcoal); margin: 0.25rem 0;">{{ team.seniorAgent.name }}</h3>
                                <p style="font-size: 0.92rem; line-height: 1.5; opacity: 0.85; margin: 0.5rem 0 0 0; text-align: justify;">Joe serves as your strategic real estate advisor, bringing decades of deep market insight and advocacy to your side.</p>
                            </div>
                            <div style="border-top: 1px dashed rgba(0,0,0,0.08); padding-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; text-align: center; width: 100%; box-sizing: border-box;">
                                {% if team.seniorAgent.phone %}
                                    <a href="tel:{{ team.seniorAgent.phone | replace('-', '') }}" style="font-size: 0.88rem; font-weight: 600; color: var(--premier-charcoal); text-decoration: none; display: inline-block; margin-bottom: 0.25rem;">📞 {{ team.seniorAgent.phone }}</a>
                                {% endif %}
                                <a href="/team/{{ team.seniorAgent.slug }}/" class="btn btn-primary interactive-btn" style="display: block; width: 100%; box-sizing: border-box; padding: 0.5rem 1.25rem; font-size: 0.85rem; text-decoration: none; font-weight: 700; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                            </div>
                        </div>
                    </article>
                {% endif %}

                <!-- 2. Transaction Coordinator Card (Beth Davis) -->
                {% if team.transactionCoordinator and team.transactionCoordinator.teamPage %}
                    <article class="profile-card" style="background-color: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 8px; padding: 1.25rem; display: flex; align-items: center; gap: 1.25rem; box-sizing: border-box; width: 100%;">
                        {% if team.transactionCoordinator.photo %}
                            <img src="{{ team.transactionCoordinator.photo }}" alt="{{ team.transactionCoordinator.name }}" width="75" height="75" loading="lazy" decodes="async" style="width: 75px; height: 75px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(0,0,0,0.08); flex-shrink: 0;">
                        {% else %}
                            <div style="width: 75px; height: 75px; border-radius: 50%; background-color: var(--dynamic-bg-highlight); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; color: var(--card-accent-color); font-weight: 800;">{{ team.transactionCoordinator.name[0] }}</div>
                        {% endif %}
                        <div style="display: flex; flex-direction: column; align-items: flex-start; text-align: left; flex-grow: 1; min-width: 0; gap: 0.25rem;">
                            <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px; display: block;">{{ team.transactionCoordinator.position }}</span>
                            <h4 style="font-size: 1.2rem; font-weight: 800; color: var(--premier-charcoal); margin: 0 0 0.35rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">{{ team.transactionCoordinator.name }}</h4>
                            <a href="/team/{{ team.transactionCoordinator.slug }}/" class="btn btn-primary interactive-btn" style="display: inline-block; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 700; text-decoration: none; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                        </div>
                    </article>
                {% endif %}
            </div>

            <!-- RIGHT COLUMN CANVAS: Lending & Listing Integration -->
            <div style="display: flex; flex-direction: column; gap: 2.5rem;">
                <!-- 3. Rocket Mortgage Executive Loan Officer Card (Carly Ozuna) -->
                {% if team.loanOfficer and team.loanOfficer.teamPage %}
                    <article class="profile-card premium-shadow" style="background-color: var(--white); border-radius: 8px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06); display: flex; flex-direction: column; border-top: 5px solid var(--premier-charcoal);">
                        {% if team.loanOfficer.photo %}
                            <img src="{{ team.loanOfficer.photo }}" alt="{{ team.loanOfficer.name }}" width="400" height="380" loading="lazy" decodes="async" style="width: 100%; max-height: 380px; object-fit: cover; display: block;">
                        {% endif %}
                        <div style="padding: 1.75rem; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; gap: 1rem;">
                            <div style="text-align: left;">
                                <span style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: var(--premier-charcoal); opacity: 0.7; letter-spacing: 0.5px;">{{ team.loanOfficer.position }}</span>
                                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--premier-charcoal); margin: 0.25rem 0;">{{ team.loanOfficer.name }}</h3>
                                <p style="font-size: 0.92rem; line-height: 1.5; opacity: 0.85; margin: 0.5rem 0 0 0; text-align: justify;">Carly directs mortgage portfolios, deploying tailored capital structuring parameters to fuel home purchase paths.</p>
                            </div>
                            <div style="border-top: 1px dashed rgba(0,0,0,0.08); padding-top: 1rem; display: flex; flex-direction: column; gap: 0.5rem; align-items: center; text-align: center; width: 100%; box-sizing: border-box;">
                                {% if team.loanOfficer.phone %}
                                    <a href="tel:{{ team.loanOfficer.phone | replace('-', '') }}" style="font-size: 0.88rem; font-weight: 600; color: var(--premier-charcoal); text-decoration: none; display: inline-block; margin-bottom: 0.25rem;">📞 {{ team.loanOfficer.phone }}</a>
                                {% endif %}
                                <a href="/team/{{ team.loanOfficer.slug }}/" class="btn btn-primary interactive-btn" style="display: block; width: 100%; box-sizing: border-box; padding: 0.5rem 1.25rem; font-size: 0.85rem; text-decoration: none; font-weight: 700; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                            </div>
                        </div>
                    </article>
                {% endif %}

                <!-- 4. Listing Coordinator Card (Rogin Ifland) -->
                {% if team.listingCoordinator and team.listingCoordinator.teamPage %}
                    <article class="profile-card" style="background-color: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 8px; padding: 1.25rem; display: flex; align-items: center; gap: 1.25rem; box-sizing: border-box; width: 100%;">
                        {% if team.listingCoordinator.photo %}
                            <img src="{{ team.listingCoordinator.photo }}" alt="{{ team.listingCoordinator.name }}" width="75" height="75" loading="lazy" decodes="async" style="width: 75px; height: 75px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(0,0,0,0.08); flex-shrink: 0;">
                        {% else %}
                            <div style="width: 75px; height: 75px; border-radius: 50%; background-color: var(--dynamic-bg-highlight); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; color: var(--card-accent-color); font-weight: 800;">{{ team.listingCoordinator.name[0] }}</div>
                        {% endif %}
                        <div style="display: flex; flex-direction: column; align-items: flex-start; text-align: left; flex-grow: 1; min-width: 0; gap: 0.25rem;">
                            <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px; display: block;">{{ team.listingCoordinator.position }}</span>
                            <h4 style="font-size: 1.2rem; font-weight: 800; color: var(--premier-charcoal); margin: 0 0 0.35rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">{{ team.listingCoordinator.name }}</h4>
                            <a href="/team/{{ team.listingCoordinator.slug }}/" class="btn btn-primary interactive-btn" style="display: inline-block; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 700; text-decoration: none; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                        </div>
                    </article>
                {% endif %}
            </div>

        </div>
    </section>

    <!-- MIDDLE TIER: COVERAGE COLLEAGUES & LEADERSHIP DEPLOYMENT LAYER -->
    <section class="coverage-leadership-block" style="margin-bottom: 4rem;">
        <h2 style="font-size: 1.5rem; font-weight: 800; border-left: 4px solid var(--card-accent-color); padding-left: 0.75rem; margin-bottom: 1.5rem; color: var(--premier-charcoal);">Coverage Colleagues & Leadership</h2>
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;" class="two-column-responsive-grid">
            
            <!-- Coverage Colleagues Loop -->
            {% for member in team.coverageColleagues %}
                {% if member.teamPage %}
                    <article class="profile-card" style="background-color: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 8px; padding: 1.25rem; display: flex; align-items: center; gap: 1.25rem; box-sizing: border-box;">
                        {% if member.photo %}
                            <img src="{{ member.photo }}" alt="{{ member.name }}" width="75" height="75" loading="lazy" decodes="async" style="width: 75px; height: 75px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(0,0,0,0.08); flex-shrink: 0;">
                        {% else %}
                            <div style="width: 75px; height: 75px; border-radius: 50%; background-color: var(--dynamic-bg-highlight); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; color: var(--card-accent-color); font-weight: 800;">{{ member.name[0] }}</div>
                        {% endif %}
                        <div style="display: flex; flex-direction: column; align-items: flex-start; text-align: left; flex-grow: 1; min-width: 0; gap: 0.25rem;">
                            <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px; display: block;">{{ member.position }}</span>
                            <h3 style="font-size: 1.2rem; font-weight: 800; color: var(--premier-charcoal); margin: 0 0 0.35rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">{{ member.name }}</h3>
                            <a href="/team/{{ member.slug }}/" class="btn btn-primary interactive-btn" style="display: inline-block; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 700; text-decoration: none; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                        </div>
                    </article>
                {% endif %}
            {% endfor %}

            <!-- Sales Manager Card (Identical Structure) -->
            {% if team.salesManager and team.salesManager.teamPage %}
                <article class="profile-card" style="background-color: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 8px; padding: 1.25rem; display: flex; align-items: center; gap: 1.25rem; box-sizing: border-box;">
                    {% if team.salesManager.photo %}
                        <img src="{{ team.salesManager.photo }}" alt="{{ team.salesManager.name }}" width="75" height="75" loading="lazy" decodes="async" style="width: 75px; height: 75px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(0,0,0,0.08); flex-shrink: 0;">
                    {% else %}
                        <div style="width: 75px; height: 75px; border-radius: 50%; background-color: var(--dynamic-bg-highlight); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--card-accent-color); font-weight: 800;">{{ team.salesManager.name[0] }}</div>
                    {% endif %}
                    <div style="display: flex; flex-direction: column; align-items: flex-start; text-align: left; flex-grow: 1; min-width: 0; gap: 0.25rem;">
                        <span style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; color: var(--card-accent-color); letter-spacing: 0.5px; display: block;">{{ team.salesManager.position }}</span>
                        <h3 style="font-size: 1.2rem; font-weight: 800; color: var(--premier-charcoal); margin: 0 0 0.35rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; width: 100%;">{{ team.salesManager.name }}</h3>
                        <a href="/team/{{ team.salesManager.slug }}/" class="btn btn-primary interactive-btn" style="display: inline-block; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 700; text-decoration: none; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white);">View Profile</a>
                    </div>
                </article>
            {% endif %}

        </div>
    </section>

    <!-- BOTTOM TIER: ASSOCIATE AGENTS GRID -->
    <section class="broker-network-block">
        <h2 style="font-size: 1.5rem; font-weight: 800; border-left: 4px solid var(--premier-charcoal); padding-left: 0.75rem; margin-bottom: 1.5rem; color: var(--premier-charcoal);">Associate Agents</h2>
        
        <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;" class="associate-network-grid">
            {% for member in team.associateAgents %}
                {% if member.teamPage %}
                    <article style="background-color: var(--white); border: 1px solid rgba(0,0,0,0.05); border-radius: 8px; padding: 1.25rem; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: space-between; gap: 0.75rem;">
                        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem; width: 100%;">
                            {% if member.photo %}
                                <img src="{{ member.photo }}" alt="{{ member.name }}" width="80" height="80" loading="lazy" decodes="async" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(0,0,0,0.08);">
                            {% else %}
                                <div style="width: 80px; height: 80px; border-radius: 50%; background-color: var(--dynamic-bg-highlight); display: flex; align-items: center; justify-content: center; font-size: 1.35rem; color: var(--card-accent-color); font-weight: 800;">{{ member.name[0] }}</div>
                            {% endif %}
                            <div>
                                <h4 style="font-size: 1.05rem; font-weight: 800; color: var(--premier-charcoal); margin: 0;">{{ member.name }}</h4>
                                <span style="font-size: 0.75rem; font-weight: 600; opacity: 0.6; display: block; margin-top: 0.15rem;">{{ member.position }}</span>
                            </div>
                            <div style="border-top: 1px solid rgba(0,0,0,0.04); padding-top: 0.5rem; width: 100%; font-size: 0.82rem; font-weight: 600; display: flex; flex-direction: column; gap: 0.2rem; text-align: center;">
                                {% if member.phone %}
                                    <span style="color: var(--premier-charcoal);">📞 {{ member.phone }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <a href="/team/{{ member.slug }}/" class="btn btn-primary interactive-btn" style="display: inline-block; width: 100%; box-sizing: border-box; padding: 0.45rem 1rem; font-size: 0.82rem; font-weight: 700; text-decoration: none; text-align: center; border-radius: 4px; background-color: var(--premier-charcoal); color: var(--white); margin-top: 0.25rem;">View Profile</a>
                    </article>
                {% endif %}
            {% endfor %}
        </div>
    </section>

</div>

<style>
    @media (min-width: 768px) {
        .core-four-grid { grid-template-columns: 1fr 1fr !important; }
        .two-column-responsive-grid { grid-template-columns: 1fr 1fr !important; }
        .associate-network-grid { grid-template-columns: repeat(3, 1fr) !important; }
    }
    @media (min-width: 992px) {
        .associate-network-grid { grid-template-columns: repeat(4, 1fr) !important; }
    }
    .profile-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .profile-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(0,0,0,0.05) !important;
    }
    .interactive-btn {
        transition: filter 0.2s ease !important;
    }
    .interactive-btn:hover {
        filter: brightness(0.9) !important;
    }
</style>